.bin-packing-3d-container {
  width: 100%;
  height: 100%;
  position: relative;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 16rpx;
  overflow: hidden;
}

.bin-packing-canvas {
  width: 100%;
  height: 100%;
}

.truck-info {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(34, 197, 94, 0.9);
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.truck-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.truck-util {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.truck-nav {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.nav-btn {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 16rpx;
}

.nav-btn.disabled {
  background: #d1d5db;
  color: #9ca3af;
}

.nav-info {
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
}
