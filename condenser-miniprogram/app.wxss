/* ==================== 全局色彩系统 ==================== */
page {
  /* 主色调 - 专业蓝 */
  --color-primary: #2563eb;
  --color-primary-light: #3b82f6;
  --color-primary-dark: #1d4ed8;
  --color-primary-bg: #eff6ff;

  /* 辅助色 - 成功绿 */
  --color-success: #10b981;
  --color-success-light: #34d399;
  --color-success-bg: #d1fae5;

  /* 警告色 - 琥珀黄 */
  --color-warning: #f59e0b;
  --color-warning-light: #fbbf24;
  --color-warning-bg: #fef3c7;

  /* 危险色 - 红色 */
  --color-danger: #ef4444;
  --color-danger-light: #f87171;
  --color-danger-bg: #fee2e2;

  /* 中性色 */
  --color-text-primary: #111827;
  --color-text-secondary: #6b7280;
  --color-text-tertiary: #9ca3af;
  --color-border: #e5e7eb;
  --color-divider: #f3f4f6;
  --color-bg: #f9fafb;
  --color-white: #ffffff;

  /* 阴影系统 */
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  --shadow-card: 0 2px 8px rgba(0, 0, 0, 0.08);

  /* 圆角系统 */
  --radius-sm: 6rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;

  /* 间距系统 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  background: var(--color-bg);
}

/* ==================== 通用容器 ==================== */
.container {
  background: var(--color-white);
  min-height: 100vh;
}

/* ==================== 标签页导航 ==================== */
.tabs {
  display: flex;
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-divider);
}

.tab {
  flex: 1;
  padding: 24rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}

.tab.active {
  color: var(--color-primary);
  border-bottom-color: var(--color-primary);
  font-weight: 600;
}

/* ==================== 内容区域 ==================== */
.content {
  padding: 30rpx;
}

/* ==================== 表单组件 ==================== */
.form-group {
  margin-bottom: 30rpx;
}

.form-group .label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.form-group input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 32rpx;
  background: var(--color-bg);
  box-sizing: border-box;
  transition: all 0.3s;
}

.form-group input:focus {
  background: var(--color-white);
  border-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx rgba(37, 99, 235, 0.1);
}

.form-group picker {
  width: 100%;
  box-sizing: border-box;
}

.picker-text {
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 32rpx;
  background: var(--color-bg);
  color: var(--color-text-primary);
}

/* ==================== 信息框 ==================== */
.info-box {
  background: var(--color-success-bg);
  border: 1rpx solid var(--color-success);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-top: 30rpx;
}

.info-box text {
  display: block;
  font-size: 26rpx;
  color: var(--color-success);
  line-height: 1.6;
}

.result-box {
  background: var(--color-primary-bg);
  border: 1rpx solid var(--color-primary);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-top: 30rpx;
}

.result-box text {
  display: block;
  font-size: 26rpx;
  color: var(--color-primary);
  line-height: 1.8;
}

/* ==================== 按钮 ==================== */
.calc-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #1e40af 0%, #60a5fa 100%);
  color: var(--color-white);
  border: none;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 64, 175, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.calc-btn:active {
  box-shadow: 0 2rpx 8rpx rgba(30, 64, 175, 0.3);
  transform: scale(0.98);
}

/* ==================== 标题 ==================== */
.section-title {
  font-size: 30rpx;
  color: var(--color-text-primary);
  margin: 40rpx 0 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--color-divider);
  font-weight: 600;
}

/* ==================== 骨架屏加载 ==================== */
.skeleton {
  animation: shimmer 1.5s infinite;
  background: linear-gradient(90deg, #f3f4f6 25%, #e5e7eb 50%, #f3f4f6 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-md);
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 骨架屏 - 卡片 */
.skeleton-card {
  height: 200rpx;
  margin: 20rpx;
  border-radius: var(--radius-lg);
}

/* 骨架屏 - 行 */
.skeleton-row {
  height: 40rpx;
  margin: 20rpx;
  border-radius: var(--radius-sm);
}

/* 骨架屏 - 头像 */
.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

/* 骨架屏 - 标题 */
.skeleton-title {
  height: 48rpx;
  width: 60%;
  margin: 20rpx;
  border-radius: var(--radius-md);
}

/* 骨架屏 - 文本 */
.skeleton-text {
  height: 32rpx;
  margin: 16rpx 20rpx;
  border-radius: var(--radius-sm);
}

.skeleton-text.short {
  width: 40%;
}

.skeleton-text.long {
  width: 80%;
}

/* ==================== 空状态 - 优化版 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
}

/* 空状态 - 图标占位符（纯 CSS） */
.empty-icon-placeholder {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
  background: linear-gradient(135deg, var(--color-divider) 0%, #e5e7eb 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  opacity: 0.3;
}

.empty-icon-placeholder::before {
  content: '';
  width: 100rpx;
  height: 100rpx;
  border: 8rpx solid var(--color-text-tertiary);
  border-radius: 50%;
  border-top-color: transparent;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  line-height: 1.6;
  max-width: 500rpx;
}

.empty-action {
  margin-top: 40rpx;
  padding: 20rpx 60rpx;
  background: var(--color-primary);
  color: var(--color-white);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: 500;
}

/* ==================== 加载状态 ==================== */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--color-divider);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* ==================== 页面过渡动画 ==================== */
.fade-in {
  animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.slide-up {
  animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
