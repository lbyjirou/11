page {
  background: linear-gradient(180deg, #f0fdf4 0%, #ecfdf5 50%, #f5f5f5 100%);
}

.page { padding: 20rpx 30rpx; min-height: 100vh; }

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title { font-size: 34rpx; font-weight: 600; color: #166534; }

.add-btn {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 32rpx !important;
  font-size: 24rpx !important;
}
.add-btn::after { border: none; }

/* 角色卡片 */
.role-list { padding-bottom: 20rpx; }

.role-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(34, 197, 94, 0.08);
}

.role-info { flex: 1; min-width: 0; }

.role-name {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.role-code { font-size: 24rpx; color: #9ca3af; }

.system-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.role-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.role-stage {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.role-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 16rpx;
}

.action-link {
  font-size: 24rpx;
  color: #2563eb;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(59, 130, 246, 0.1);
  text-align: center;
}
.action-link.danger {
  color: #dc2626;
  background: rgba(239, 68, 68, 0.1);
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
  color: #9ca3af;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  width: 85%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 24rpx;
}

.form-item { margin-bottom: 20rpx; }

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.form-item .input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #374151;
  box-sizing: border-box;
}

.form-item .input[disabled] {
  background: #f3f4f6;
  color: #9ca3af;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn { border-radius: 32rpx !important; font-size: 26rpx !important; }
.btn::after { border: none; }
.btn.cancel {
  background: #f3f4f6 !important;
  color: #6b7280 !important;
}
.btn.confirm {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%) !important;
  color: #fff !important;
}

/* 权限面板 */
.perm-panel { max-height: 80vh; }

.perm-scroll { max-height: 55vh; }

.perm-group { margin-bottom: 20rpx; }

.group-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #166534;
  padding: 8rpx 0;
  border-bottom: 2rpx solid #e5e7eb;
  margin-bottom: 12rpx;
}

.perm-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 8rpx;
  font-size: 26rpx;
  color: #374151;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #22c55e;
  border-color: #22c55e;
  position: relative;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 4rpx;
  width: 12rpx;
  height: 20rpx;
  border: 3rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}
