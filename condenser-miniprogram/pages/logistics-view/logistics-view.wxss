/* 物流价格查询页 */

page {
  background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 50%, #f5f5f5 100%);
}

.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 88rpx 30rpx 20rpx;
  background: linear-gradient(180deg, #eff6ff 0%, transparent 100%);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(59, 130, 246, 0.1);
  margin-right: 20rpx;
}

.back-btn:active {
  background: rgba(59, 130, 246, 0.2);
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #3b82f6;
  border-bottom: 4rpx solid #3b82f6;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
  color: #1e40af;
}

/* 导入按钮 */
.import-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.import-btn:active {
  opacity: 0.8;
}

.import-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.import-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* 方向切换 */
.direction-tabs {
  display: flex;
  padding: 0 30rpx;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.direction-tabs .tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.direction-tabs .tab-item.active {
  background: #fff;
  border-color: #3b82f6;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.2);
}

.direction-tabs .tab-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.direction-tabs .tab-text {
  font-size: 24rpx;
  color: #6b7280;
}

.direction-tabs .tab-item.active .tab-text {
  color: #3b82f6;
  font-weight: 500;
}

/* 有效期提示 */
.expire-info {
  display: flex;
  align-items: center;
  margin: 0 30rpx 20rpx;
  padding: 16rpx 24rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 12rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

.expire-info.expired {
  background: rgba(239, 68, 68, 0.1);
  border-color: rgba(239, 68, 68, 0.3);
}

.expire-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.expire-text {
  flex: 1;
  font-size: 24rpx;
  color: #3b82f6;
}

.expire-info.expired .expire-text {
  color: #ef4444;
  font-weight: 500;
}

/* 地点选择 */
.location-section {
  padding: 0 30rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.location-scroll {
  width: 100%;
  white-space: nowrap;
}

.location-list {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.location-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #374151;
  transition: all 0.3s;
}

.location-tag.active {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

/* 价格区域 */
.price-area {
  flex: 1;
  height: 0;
  padding: 0 30rpx;
}

/* 空状态/加载状态 */
.empty-state,
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text,
.loading-state text {
  font-size: 28rpx;
  color: #9ca3af;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(59, 130, 246, 0.2);
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 价格列表 */
.price-list {
  padding: 20rpx 0;
}

.route-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.route-text {
  display: inline-block;
  padding: 8rpx 32rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

/* 公司卡片 */
.company-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(59, 130, 246, 0.08);
}

.company-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.company-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.min-charge {
  font-size: 22rpx;
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 价格网格 */
.price-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.price-item {
  flex: 0 0 calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}

.price-label {
  font-size: 20rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
  text-align: center;
}

.price-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #ea580c;
}

/* 散货备注 */
.scatter-remark {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fef3c7;
  border-radius: 12rpx;
  border-left: 4rpx solid #f59e0b;
}

.remark-label {
  font-size: 22rpx;
  color: #92400e;
  font-weight: 500;
}

.remark-text {
  font-size: 22rpx;
  color: #78350f;
  line-height: 1.5;
}

.bottom-placeholder {
  height: 40rpx;
}

/* ==================== 导入预览弹窗 ==================== */

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 90%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #9ca3af;
}

/* 识别状态 */
.recognize-status {
  padding: 20rpx 30rpx;
  font-size: 26rpx;
}

.recognize-status.success {
  background: #ecfdf5;
  color: #059669;
}

.recognize-status.warning {
  background: #fffbeb;
  color: #d97706;
}

/* 区域滚动 */
.regions-scroll {
  flex: 1;
  max-height: 60vh;
  padding: 20rpx 30rpx;
}

/* 区域卡片 */
.region-card {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.region-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.region-direction {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b82f6;
  background: rgba(59, 130, 246, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.region-info {
  font-size: 22rpx;
  color: #9ca3af;
}

/* 映射部分 */
.mapping-section {
  margin-bottom: 16rpx;
}

.mapping-title,
.preview-title {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
  display: block;
}

.mapping-list {
  background: #fff;
  border-radius: 12rpx;
  padding: 12rpx;
}

.mapping-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  font-size: 24rpx;
}

.field-name {
  color: #374151;
  font-weight: 500;
  min-width: 120rpx;
}

.arrow {
  color: #9ca3af;
  margin: 0 12rpx;
}

.col-header {
  color: #6b7280;
  flex: 1;
}

.confidence {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.confidence.HIGH {
  background: #ecfdf5;
  color: #059669;
}

.confidence.MEDIUM {
  background: #fffbeb;
  color: #d97706;
}

.confidence.LOW {
  background: #fef2f2;
  color: #dc2626;
}

/* 预览表格 */
.preview-section {
  margin-top: 12rpx;
}

.preview-table-scroll {
  background: #fff;
  border-radius: 12rpx;
  white-space: nowrap;
}

.preview-table {
  display: inline-block;
  min-width: 100%;
}

.preview-row {
  display: flex;
  border-bottom: 1rpx solid #f3f4f6;
}

.preview-row.header {
  background: #f9fafb;
}

.preview-row.header .preview-cell {
  font-weight: 600;
  color: #374151;
}

.preview-cell {
  min-width: 140rpx;
  padding: 16rpx 12rpx;
  font-size: 22rpx;
  color: #6b7280;
  text-align: center;
}

/* 未映射列 */
.unmapped-section {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #fef2f2;
  border-radius: 12rpx;
}

.unmapped-title {
  font-size: 24rpx;
  color: #dc2626;
  margin-bottom: 12rpx;
  display: block;
}

.unmapped-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.unmapped-tag {
  font-size: 22rpx;
  color: #9ca3af;
  background: #fff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 弹窗底部 */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f3f4f6;
}

.modal-footer button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  margin: 0;
}

.btn-cancel {
  background: #f3f4f6 !important;
  color: #6b7280 !important;
}

.btn-confirm {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%) !important;
  color: #fff !important;
}
