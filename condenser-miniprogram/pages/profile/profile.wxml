<view class="container">
  <view class="user-card">
    <view class="avatar">
      <text class="avatar-text">{{userInfo.realName ? userInfo.realName[0] : 'U'}}</text>
    </view>
    <view class="user-info">
      <text class="name">{{userInfo.realName || userInfo.username}}</text>
      <text class="role">{{roleText}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" wx:if="{{canManageProcess}}" bindtap="goToProcessManage">
      <text class="menu-icon">🔧</text>
      <text class="menu-text">工序管理</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" wx:if="{{canManageSpec}}" bindtap="goToSpecManage">
      <text class="menu-icon">📦</text>
      <text class="menu-text">规格库管理</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" wx:if="{{canViewLogistics}}" bindtap="goToLogisticsView">
      <text class="menu-icon">🚚</text>
      <text class="menu-text">物流价格查询</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" wx:if="{{canManageUser}}" bindtap="goToUserManage">
      <text class="menu-icon">👥</text>
      <text class="menu-text">用户管理</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" wx:if="{{canManageRole}}" bindtap="goToRoleManage">
      <text class="menu-icon">🔑</text>
      <text class="menu-text">角色管理</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" wx:if="{{canManageConfig}}" bindtap="goToConfig">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">系统配置</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" wx:if="{{canManageConfig}}" bindtap="goToDeadlineSettings">
      <text class="menu-icon">⏰</text>
      <text class="menu-text">交期约束设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <button class="logout-btn" bindtap="onLogout">退出登录</button>
</view>
