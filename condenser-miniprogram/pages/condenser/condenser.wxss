}
.cp-col-add.common {
  color: #6b7280;
  background: rgba(107, 114, 128, 0.05);
  border-color: #d1d5db;
}

.cp-summary-edit-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.cp-summary-input {
  flex: 1;
  font-size: 24rpx;
}

.picker-display {
  display: flex;
  align-items: center;
  min-height: 72rpx;
