/* ==================== 审批Tab样式 ==================== */
.approve-panel {
  padding-bottom: 40rpx;
}

.approve-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(34, 197, 94, 0.08);
  box-sizing: border-box;
  width: 100%;
}

/* 成本汇总 - 键值对行 */
.approve-kv {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.approve-kv-label {
  font-size: 28rpx;
  color: #6b7280;
  flex-shrink: 0;
}

.approve-kv-val {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  font-family: monospace;
}

.approve-kv-val.highlight {
  color: #166534;
  font-size: 32rpx;
  font-weight: 700;
}

.approve-card-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #e5e7eb, transparent);
  margin: 8rpx 0;
}

/* 费用明细 - 费率行 */
.approve-fee-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.approve-fee-label {
  width: 120rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #6b7280;
}

.approve-fee-inputs {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.approve-fee-rate {
  width: 160rpx;
  flex-shrink: 0;
  height: 60rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #374151;
  background: #f9fafb;
  text-align: center;
  font-family: monospace;
  box-sizing: border-box;
}

.approve-fee-eq {
  font-size: 24rpx;
  color: #9ca3af;
  flex-shrink: 0;
}

.approve-fee-result {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  line-height: 60rpx;
  background: #f0fdf4;
  border: 1rpx solid #bbf7d0;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #166534;
  text-align: right;
  font-family: monospace;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
