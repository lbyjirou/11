}
.cp-col-input.name { flex: 2; min-width: 0; }
.cp-col-input.key { flex: 2; min-width: 0; font-family: monospace; color: #3b82f6; }
.cp-col-input.unit { width: 80rpx; flex: 0 0 80rpx; }
.cp-col-input.formula { flex: 1; min-width: 0; font-family: monospace; color: #8b5cf6; }
.cp-col-input.default-val { flex: 1; min-width: 0; color: #6b7280; }
.cp-col-tag {
