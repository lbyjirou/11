  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.quote-no {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.quote-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
