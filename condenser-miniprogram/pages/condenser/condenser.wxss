}
.cp-subtotal-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  font-weight: 700;
  color: #2563eb;
  font-family: monospace;
}

/* 全局合计 */
.cp-grand-total {
  padding: 24rpx;
  background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);
}
.cp-grand-total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.cp-grand-total-label {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
}
.cp-grand-total-value {
  font-size: 36rpx;
