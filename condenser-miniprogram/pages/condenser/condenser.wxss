/* 冷凝器报价页 - 生态未来主义风格 */

/* 页面容器 */
page {
  background: linear-gradient(180deg, #f0fdf4 0%, #ecfdf5 50%, #f5f5f5 100%);
}

.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ==================== 自定义导航栏 ==================== */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 88rpx 30rpx 20rpx;
  background: linear-gradient(180deg, #f0fdf4 0%, transparent 100%);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(34, 197, 94, 0.1);
  margin-right: 20rpx;
  transition: all 0.2s ease;
}

.back-btn:active {
  background: rgba(34, 197, 94, 0.2);
  transform: scale(0.95);
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #22c55e;
  border-bottom: 4rpx solid #22c55e;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #166534;
  flex: 1;
}

/* 通知铃铛 */
.nav-bell {
  position: relative;
  padding: 10rpx;
  font-size: 36rpx;
}

.bell-badge {
  position: absolute;
  top: 2rpx;
  right: 0;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  font-size: 18rpx;
  color: #fff;
  background: #ff4d4f;
  border-radius: 14rpx;
  padding: 0 6rpx;
}

/* 通知列表项 */
.notification-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.notification-item.read {
  opacity: 0.6;
}

.notification-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.notification-type {
  font-size: 22rpx;
  color: #ff4d4f;
  background: #fff2f0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.notification-type.escalation {
  color: #d4380d;
  background: #fff1f0;
}

.notification-type.warning {
  color: #d48806;
  background: #fffbe6;
}

.notification-msg {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
}

.notification-time {
  font-size: 22rpx;
  color: #999;
  display: block;
}

/* ==================== 一级Tab ==================== */
.main-tabs {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 12rpx;
  background: transparent;
  flex-wrap: nowrap;
  overflow-x: auto;
}

.main-tab {
  flex: 1;
  min-width: 80rpx;
  max-width: 120rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.6);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.main-tab text {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
  white-space: nowrap;
}

.main-tab.active {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.3);
}

.main-tab.active text {
  color: #fff;
}

.main-tab:active {
  transform: scale(0.98);
}

/* ==================== 流程进度条 ==================== */
.progress-bar {
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-bottom: 1rpx solid #e5e7eb;
}

.modification-banner {
  text-align: center;
  font-size: 22rpx;
  color: #f59e0b;
  background: #fef3c7;
  padding: 6rpx 0;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.deadline-banner {
  text-align: center;
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 12rpx 24rpx;
  margin: 0 24rpx 12rpx;
  border-radius: 8rpx;
}

.deadline-banner.overdue {
  color: #ff4d4f;
  background: #fff2f0;
}

.progress-stages {
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.stage-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  background: #e5e7eb;
  color: #9ca3af;
}

.progress-stage.completed .stage-dot {
  background: #22c55e;
  color: #fff;
}

.progress-stage.current .stage-dot {
  background: #3b82f6;
  color: #fff;
  box-shadow: 0 0 0 4rpx rgba(59, 130, 246, 0.2);
}

.progress-stage.rejected .stage-dot {
  background: #ef4444;
  color: #fff;
}

.stage-label {
  font-size: 18rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  white-space: nowrap;
}

.progress-stage.completed .stage-label {
  color: #16a34a;
}

.progress-stage.current .stage-label {
  color: #2563eb;
  font-weight: 500;
}

.stage-line {
  width: 30rpx;
  height: 2rpx;
  background: #e5e7eb;
  margin: 0 2rpx;
  margin-bottom: 24rpx;
}

.stage-line.completed {
  background: #22c55e;
}

/* ==================== 二级Tab（药丸按钮） ==================== */
.sub-tabs {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 16rpx 30rpx 24rpx;
}

.sub-tab {
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid #e5e7eb;
  font-size: 26rpx;
  color: #6b7280;
  transition: all 0.3s ease;
}

.sub-tab.active {
  background: rgba(34, 197, 94, 0.1);
  border-color: #22c55e;
  color: #16a34a;
  font-weight: 500;
}

.sub-tab:active {
  transform: scale(0.98);
}

/* ==================== 内容区域 ==================== */
.content-area {
  flex: 1;
  padding: 0;
  overflow: visible;
}

.panel {
  padding: 0 30rpx;
  padding-bottom: 40rpx;
}

/* ==================== 卡片样式 ==================== */
.card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(34, 197, 94, 0.08);
  overflow: visible;
}

.card-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(34, 197, 94, 0.1);
  overflow: visible;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #166534;
}

.toggle-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  padding-right: 10rpx;
}

.toggle-header .card-title {
  flex: 1;
  min-width: 0;
}

.toggle-arrow {
  flex-shrink: 0;
  width: 24rpx;
  height: 24rpx;
  margin-left: 20rpx;
  border-right: 5rpx solid #166534;
  border-bottom: 5rpx solid #166534;
  transform: rotate(45deg);
  transition: transform 0.25s ease;
}

.toggle-arrow.expanded {
  transform: rotate(-135deg);
}

/* ==================== 表单样式 ==================== */
.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}
.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.form-item-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.form-item-half { flex: 1; }
.form-label-sm {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #374151;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: #22c55e;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(34, 197, 94, 0.1);
}

.form-input.disabled {
  background: #f3f4f6;
  color: #9ca3af;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

.form-item.third {
  flex: 1;
}

/* 客户搜索底部半屏 */
.customer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 998;
  display: flex;
  align-items: flex-end;
}

.customer-sheet {
  width: 100%;
  max-height: 60vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.customer-sheet-header {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}

.customer-sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.customer-sheet-add {
  color: #07c160;
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  border: 2rpx solid #07c160;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.customer-sheet-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.customer-sheet-list {
  flex: 1;
  max-height: 50vh;
  padding: 0 32rpx;
}

.customer-search-bar {
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.customer-search-input {
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

/* 输入框带搜索图标 */
.input-with-icon {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.input-with-icon .flex-input {
  flex: 1;
  min-width: 0;
}

.search-icon {
  font-size: 32rpx;
  padding: 8rpx 12rpx;
  flex-shrink: 0;
}

/* 客户名称输入联想下拉 */
.customer-name-wrapper {
  position: relative;
}

.customer-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 0 0 12rpx 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  max-height: 400rpx;
  overflow-y: auto;
}

.customer-dropdown-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.customer-dropdown-item:last-child {
  border-bottom: none;
}

.customer-dropdown-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.customer-dropdown-tag {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 12rpx;
}

.customer-list-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.customer-list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.customer-list-main {
  flex: 1;
}

.customer-list-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.customer-list-info {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.customer-list-code,
.customer-list-tier {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.customer-list-actions {
  display: flex;
  gap: 16rpx;
}

.customer-action-btn {
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
}

.customer-action-btn.edit {
  color: #1890ff;
  background: #e6f7ff;
}

.customer-action-btn.delete {
  color: #ff4d4f;
  background: #fff2f0;
}

/* 模具费单选按钮 */
.radio-group-row {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
}

.radio-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  flex: 1;
  justify-content: center;
}

.radio-option.active {
  border-color: #07c160;
  background: #f0fdf4;
  color: #333;
}

.radio-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  position: relative;
}

.radio-dot.checked {
  border-color: #07c160;
}

.radio-dot.checked::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #07c160;
}

.mold-hint {
  padding: 16rpx 0 0;
}

.hint-text {
  font-size: 24rpx;
  color: #999;
}

/* 交期分配 */
.dl-stage-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 4rpx;
}
.dl-stage-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.dl-stage-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #374151;
  flex-shrink: 0;
}
.dl-stage-input {
  flex: 1;
  height: 64rpx;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  text-align: center;
}
.dl-stage-unit {
  width: 40rpx;
  font-size: 24rpx;
  color: #6b7280;
  flex-shrink: 0;
}
.dl-total-hint {
  margin-top: 12rpx;
  text-align: right;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: relative;
  z-index: 1;
  width: 85%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
}

.modal-header {
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}
.modal-footer-row {
  display: flex;
  gap: 16rpx;
  width: 100%;
}
.modal-footer-row .confirm-btn {
  flex: 1;
}
.save-preset-btn {
  flex: none;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #059669;
  background: #ecfdf5;
  border: 1rpx solid #a7f3d0;
  border-radius: 12rpx;
  line-height: 2.2;
}
.energy-preset-del {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  color: #ef4444;
  font-size: 28rpx;
}
/* 行级公式 */
.row-formula-input-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.row-formula-prefix {
  font-size: 24rpx;
  font-weight: 600;
  color: #7c3aed;
  font-style: italic;
  flex: none;
}
.row-formula-input {
  flex: 1;
  font-size: 24rpx;
  font-family: monospace;
  color: #7c3aed;
}
.has-custom-formula {
  color: #7c3aed !important;
  text-decoration: underline;
  text-decoration-style: dotted;
}
.row-formula-modal {
  width: 90%;
}
.row-formula-edit {
  font-family: monospace;
}
.row-formula-hint {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #07c160;
  color: #fff;
}

/* Picker 样式 */
.form-picker {
  width: 100%;
}

.picker-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #374151;
}

/* ==================== 计算按钮 ==================== */
.calc-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  border-radius: 44rpx;
  border: none;
  margin: 30rpx 0;
  box-shadow: 0 6rpx 20rpx rgba(34, 197, 94, 0.3);
  transition: all 0.3s ease;
}

.calc-btn::after {
  border: none;
}

.calc-btn text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.calc-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(34, 197, 94, 0.2);
}

.calc-btn.loading {
  opacity: 0.8;
}

.btn-loading {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ==================== 结果卡片 ==================== */
.result-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(16, 185, 129, 0.1) 100%);
  border: 2rpx solid rgba(34, 197, 94, 0.2);
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.result-card.triple {
  padding: 28rpx 16rpx;
}

.result-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.result-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #166534;
  line-height: 1.2;
}

.result-card.triple .result-value {
  font-size: 36rpx;
}

.result-label {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.result-unit {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.result-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(34, 197, 94, 0.2);
}

/* ==================== 设置页特殊样式 ==================== */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.info-text {
  font-size: 28rpx;
  color: #374151;
}

.info-link {
  font-size: 24rpx;
  color: #22c55e;
}

.current-price {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 30rpx 0 10rpx;
  gap: 8rpx;
}

.price-label {
  font-size: 24rpx;
  color: #6b7280;
}

.price-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #ea580c;
}

.price-unit {
  font-size: 24rpx;
  color: #6b7280;
}

/* ==================== 汇总页样式 ==================== */
.summary-panel {
  padding-bottom: 160rpx;
}

.section-header {
  padding: 20rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #166534;
}

.material-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(34, 197, 94, 0.08);
}

.material-item {
