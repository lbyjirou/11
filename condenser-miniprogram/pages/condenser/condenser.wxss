}

.quote-project {
  font-size: 24rpx;
  color: #9ca3af;
}

.quote-item-footer {
  display: flex;
  justify-content: flex-end;
}

.quote-time {
  font-size: 22rpx;
  color: #9ca3af;
}

/* ==================== 编辑模式 ==================== */
.edit-mode-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.main-tabs-wrapper {
  display: flex;
  align-items: center;
  background: #fff;
  border-bottom: 1rpx solid #e5e7eb;
  padding-right: 20rpx;
}

.main-tabs-wrapper .main-tabs {
  flex: 1;
  border-bottom: none;
}

.exit-btn {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 24rpx;
  margin-left: 16rpx;
}

.exit-btn:active {
  background: #e5e7eb;
}

.content-area.has-bottom-bar {
  padding-bottom: 140rpx;
}

