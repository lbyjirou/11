  border-bottom: 1rpx solid #e5e7eb;
}

.quote-list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.create-quote-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
