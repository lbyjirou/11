  font-size: 24rpx;
  background: #fff;
}
.row-action-btn {
  font-size: 20rpx; padding: 6rpx 12rpx; border-radius: 6rpx; line-height: 1;
}
.row-action-btn.copy { background: rgba(59,130,246,0.1); color: #2563eb; }
.row-action-btn.move { background: rgba(156,163,175,0.1); color: #6b7280; }
