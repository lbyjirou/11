}

.approve-fee-single {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #374151;
  background: #f9fafb;
  text-align: right;
  font-family: monospace;
  box-sizing: border-box;
}

/* 报价结果 */
.approve-result-card {
  background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
  border: 1rpx solid #bbf7d0;
}

.approve-result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.approve-result-label {
  font-size: 28rpx;
  color: #6b7280;
}

.approve-result-val {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
  font-family: monospace;
}

.approve-result-row.main .approve-result-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #166534;
}

.approve-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: rgba(34, 197, 94, 0.1);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.status-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #22c55e;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
}

.status-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #166534;
}

.approve-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(59, 130, 246, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.approve-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ==================== 报价单列表模式 ==================== */
.quote-list-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
}

.quote-list-header {
