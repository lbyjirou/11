  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.cp-col-tag.input { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
.cp-col-tag.output { background: rgba(139, 92, 246, 0.1); color: #8b5cf6; }
.cp-col-btns {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}
.cp-col-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6b7280;
  background: #f3f4f6;
