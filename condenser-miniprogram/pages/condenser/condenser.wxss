}
.cp-col-btn.danger { color: #ef4444; background: rgba(239, 68, 68, 0.1); }
.cp-col-add-row {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}
.cp-col-add {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  color: #3b82f6;
  font-size: 26rpx;
