}
.cp-fee-label { font-size: 22rpx; color: #92400e; flex-shrink: 0; }
.cp-fee-input {
  width: 160rpx;
  height: 48rpx;
  border: 1rpx solid #fde68a;
  border-radius: 8rpx;
