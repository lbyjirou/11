                    <view class="area-summary-check">{{sec.includedInSummary === false ? '☐' : '☑'}}</view>
                    <text class="area-summary-name">{{sec.label}}</text>
                    <text class="area-summary-val">¥{{sec.subtotalValue || '0'}}</text>
                  </view>
                  <view class="area-summary-empty" wx:if="{{!customProcessData.energySections.length}}">暂无能耗区域</view>
                </block>
                <block wx:if="{{areaSummaryDtype === 'moldFee'}}">
                  <view class="area-summary-item {{sec.includedInSummary === false ? 'excluded' : ''}}" wx:for="{{customProcessData.moldFeeSections}}" wx:key="key" wx:for-item="sec" catchtap="toggleSectionInSummary" data-skey="{{sec.key}}" data-dtype="moldFee">
