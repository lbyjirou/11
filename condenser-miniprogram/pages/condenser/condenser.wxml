                        <block wx:if="{{p.role === 'output'}}">
                          <text class="device-card-grid-output" catchtap="openRowFormulaEditor" data-skey="{{sec.key}}" data-id="{{row.id}}" data-field="{{p.key}}" data-dtype="energy">= {{row[p.key] || '0'}}</text>
                        </block>
                        <block wx:elif="{{!prodReadonly}}">
                          <input class="device-card-grid-input" type="{{p.type === 'number' ? 'digit' : 'text'}}" value="{{row[p.key]}}" bindinput="onCustomProcessInput" data-skey="{{sec.key}}" data-id="{{row.id}}" data-field="{{p.key}}" data-dtype="energy" />
                        </block>
                        <block wx:else>
                          <text class="device-card-grid-val">{{row[p.key] || '-'}}</text>
                        </block>
