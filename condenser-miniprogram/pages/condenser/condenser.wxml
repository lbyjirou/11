          <text class="card-title">规格名称</text>
        </view>
        <view class="form-item spec-name-row">
          <picker class="spec-name-picker" bindchange="onTubePresetChange" value="{{tubePresetIndex}}" range="{{tubePresetNames}}">
            <view class="spec-name-picker-btn">选择</view>
          </picker>
          <input class="form-input flex-input" value="{{tubeSpecName}}" bindinput="onTubeSpecNameInput" placeholder="输入或选择规格名称" />
        </view>
      </view>

      <view class="card">
        <view class="card-header">
          <text class="card-title">尺寸参数</text>
        </view>
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">米重（kg/m）</text>
            <input class="form-input" type="digit" value="{{tubeMeterWeight}}" bindinput="onTubeMeterWeightInput" />
          </view>
          <view class="form-item half">
            <text class="form-label">长度（mm）</text>
            <input class="form-input" type="digit" value="{{tubeLen}}" bindinput="onTubeLenInput" />
          </view>
        </view>
      </view>

      <view class="card">
        <view class="card-header">
          <text class="card-title">加工费用</text>
        </view>
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">普通加工费（元）</text>
            <input class="form-input" type="digit" value="{{tubeFee}}" bindinput="onTubeFeeInput" />
          </view>
          <view class="form-item half">
            <text class="form-label">喷锌加工费（元）</text>
            <input class="form-input" type="digit" value="{{tubeZincFee}}" bindinput="onTubeZincFeeInput" />
          </view>
        </view>
      </view>

      <button class="calc-btn {{isCalculating ? 'loading' : ''}}" bindtap="calcTube" disabled="{{isCalculating}}">
        <view class="btn-loading" wx:if="{{isCalculating}}"></view>
        <text>{{isCalculating ? '计算中' : '计算'}}</text>
      </button>

      <view class="result-card triple" wx:if="{{tubeResult.weight > 0}}">
        <view class="result-item">
          <text class="result-value">{{tubeResult.weight}}</text>
          <text class="result-label">单根重量</text>
          <text class="result-unit">kg</text>
        </view>
        <view class="result-divider"></view>
        <view class="result-item">
          <text class="result-value">{{tubeResult.normalPrice}}</text>
          <text class="result-label">普通价格</text>
          <text class="result-unit">元</text>
        </view>
        <view class="result-divider"></view>
        <view class="result-item">
          <text class="result-value">{{tubeResult.zincPrice}}</text>
          <text class="result-label">喷锌价格</text>
          <text class="result-unit">元</text>
        </view>
      </view>

      <view class="spec-btn-row" wx:if="{{tubeResult.weight > 0}}">
        <button class="save-spec-btn flex-btn" bindtap="saveTubeSpec">
          {{tubePresetIndex > 0 ? '更新到规格库' : '添加到规格库'}}
        </button>
        <button class="delete-spec-btn" wx:if="{{tubePresetIndex > 0}}" bindtap="deleteTubeSpec">删除规格</button>
      </view>
    </view>

    <!-- ==================== 汇总页 ==================== -->
    <view class="panel summary-panel" wx:if="{{mainTab === 'summary'}}">
      <!-- 主要材料 - 购物车模式 -->
      <view class="section-header">
        <text class="section-title">主要材料</text>
      </view>

      <view class="material-card">
        <!-- 集流管 -->
        <view class="cart-section">
          <view class="cart-header">
            <text class="cart-title">集流管</text>
            <view class="add-btn" bindtap="openSpecPicker" data-type="collector">+ 添加</view>
          </view>
          <view class="cart-list" wx:if="{{cartCollectors.length > 0}}">
            <view class="cart-item" wx:for="{{cartCollectors}}" wx:key="index">
              <view class="cart-item-name-wrap">
                <input class="cart-item-name-input" value="{{item.name}}"
                  bindinput="onCartNameInput" bindfocus="onCartNameFocus" bindblur="onCartNameBlur"
                  data-type="collector" data-idx="{{index}}" placeholder="输入规格名" />
                <view class="cart-name-suggest" wx:if="{{cartEditingType === 'collector' && cartEditingIdx === index && cartSuggestList.length > 0}}">
                  <view class="suggest-item" wx:for="{{cartSuggestList}}" wx:for-item="spec" wx:key="id"
                    catchtap="onSelectCartSuggest" data-type="collector" data-idx="{{index}}" data-spec-id="{{spec.id}}">
                    {{spec.name}}
                  </view>
                </view>
              </view>
              <view class="cart-qty-wrap">
                <view class="qty-btn" catchtap="onCartQtyMinus" data-type="collector" data-idx="{{index}}">-</view>
                <input class="cart-qty-input" type="number" value="{{item.qty}}" bindinput="onCartQtyInput" data-type="collector" data-idx="{{index}}" />
                <view class="qty-btn" catchtap="onCartQtyPlus" data-type="collector" data-idx="{{index}}">+</view>
              </view>
              <text class="cart-item-subtotal">¥{{item.subtotal}}</text>
              <view class="cart-delete-btn" catchtap="onCartDelete" data-type="collector" data-idx="{{index}}">删除</view>
            </view>
          </view>
          <view class="cart-empty" wx:else>
            <text>暂无集流管，点击添加</text>
          </view>
        </view>

        <!-- 翅片 -->
        <view class="cart-section">
          <view class="cart-header">
            <text class="cart-title">翅片</text>
            <view class="add-btn" bindtap="openSpecPicker" data-type="fin">+ 添加</view>
          </view>
          <view class="cart-list" wx:if="{{cartFins.length > 0}}">
            <view class="cart-item" wx:for="{{cartFins}}" wx:key="index">
              <view class="cart-item-name-wrap">
                <input class="cart-item-name-input" value="{{item.name}}"
                  bindinput="onCartNameInput" bindfocus="onCartNameFocus" bindblur="onCartNameBlur"
                  data-type="fin" data-idx="{{index}}" placeholder="输入规格名" />
                <view class="cart-name-suggest" wx:if="{{cartEditingType === 'fin' && cartEditingIdx === index && cartSuggestList.length > 0}}">
                  <view class="suggest-item" wx:for="{{cartSuggestList}}" wx:for-item="spec" wx:key="id"
                    catchtap="onSelectCartSuggest" data-type="fin" data-idx="{{index}}" data-spec-id="{{spec.id}}">
                    {{spec.name}}
                  </view>
                </view>
              </view>
              <view class="cart-qty-wrap">
                <view class="qty-btn" catchtap="onCartQtyMinus" data-type="fin" data-idx="{{index}}">-</view>
                <input class="cart-qty-input" type="number" value="{{item.qty}}" bindinput="onCartQtyInput" data-type="fin" data-idx="{{index}}" />
                <view class="qty-btn" catchtap="onCartQtyPlus" data-type="fin" data-idx="{{index}}">+</view>
              </view>
              <text class="cart-item-subtotal">¥{{item.subtotal}}</text>
              <view class="cart-delete-btn" catchtap="onCartDelete" data-type="fin" data-idx="{{index}}">删除</view>
            </view>
          </view>
          <view class="cart-empty" wx:else>
            <text>暂无翅片，点击添加</text>
          </view>
        </view>

        <!-- 扁管 -->
        <view class="cart-section">
          <view class="cart-header">
            <text class="cart-title">扁管</text>
            <view class="add-btn" bindtap="openSpecPicker" data-type="tube">+ 添加</view>
          </view>
          <view class="cart-list" wx:if="{{cartTubes.length > 0}}">
            <view class="cart-item" wx:for="{{cartTubes}}" wx:key="index">
              <view class="cart-item-name-wrap">
                <input class="cart-item-name-input" value="{{item.name}}"
                  bindinput="onCartNameInput" bindfocus="onCartNameFocus" bindblur="onCartNameBlur"
                  data-type="tube" data-idx="{{index}}" placeholder="输入规格名" />
                <view class="cart-name-suggest" wx:if="{{cartEditingType === 'tube' && cartEditingIdx === index && cartSuggestList.length > 0}}">
                  <view class="suggest-item" wx:for="{{cartSuggestList}}" wx:for-item="spec" wx:key="id"
                    catchtap="onSelectCartSuggest" data-type="tube" data-idx="{{index}}" data-spec-id="{{spec.id}}">
                    {{spec.name}}
                  </view>
                </view>
              </view>
              <view class="cart-qty-wrap">
                <view class="qty-btn" catchtap="onCartQtyMinus" data-type="tube" data-idx="{{index}}">-</view>
                <input class="cart-qty-input" type="number" value="{{item.qty}}" bindinput="onCartQtyInput" data-type="tube" data-idx="{{index}}" />
                <view class="qty-btn" catchtap="onCartQtyPlus" data-type="tube" data-idx="{{index}}">+</view>
              </view>
              <text class="cart-item-subtotal">¥{{item.subtotal}}</text>
              <view class="cart-delete-btn" catchtap="onCartDelete" data-type="tube" data-idx="{{index}}">删除</view>
            </view>
          </view>
          <view class="cart-empty" wx:else>
            <text>暂无扁管，点击添加</text>
          </view>
        </view>

        <view class="subtotal-row">
          <text>主要材料合计</text>
          <text class="subtotal-value">{{summaryData.materialCost}} 元</text>
        </view>
      </view>

      <!-- 其他部件 -->
      <view wx:if="{{components.length}}">
        <view class="section-header">
          <text class="section-title">其他部件</text>
        </view>

        <view class="material-card">
          <view class="material-item" wx:for="{{components}}" wx:key="id" wx:if="{{componentExpanded || index < componentShowCount}}">
            <view class="material-info">
              <text class="material-name">{{item.name}}</text>
              <text class="material-price">{{item.spec ? item.spec + ' ' : ''}}{{item.unit_price}}元</text>
            </view>
            <view class="material-qty">
              <input class="qty-input" type="number" value="{{componentQtys[item.id]}}" bindinput="onComponentQtyInput" data-id="{{item.id}}" />
            </view>
            <text class="material-subtotal">{{componentSubtotals[item.id]}}元</text>
          </view>

          <!-- 展开/收起按钮 -->
          <view class="expand-btn" wx:if="{{components.length > componentShowCount}}" bindtap="toggleComponentExpand">
            <text>{{componentExpanded ? '收起' : '展开更多（' + (components.length - componentShowCount) + '项）'}}</text>
            <view class="expand-arrow {{componentExpanded ? 'up' : ''}}"></view>
          </view>

          <view class="subtotal-row">
            <text>其他部件合计</text>
            <text class="subtotal-value">{{summaryData.componentCost}} 元</text>
          </view>
        </view>
      </view>

      <!-- 加工工序 -->
      <view wx:if="{{processList.length}}">
        <view class="section-header">
          <text class="section-title">加工工序</text>
        </view>

        <view class="material-card">
          <!-- 工序详情（展开时显示） -->
          <view wx:if="{{processExpanded}}">
            <view class="material-item" wx:for="{{processList}}" wx:key="id">
              <view class="material-info">
                <text class="material-name">{{item.name}}</text>
                <text class="material-price">{{item.unitPrice}}元/{{item.unitType}}</text>
              </view>
              <view class="material-qty">
                <input class="qty-input" type="number" value="{{processQtys[item.id]}}" bindinput="onProcessQtyInput" data-id="{{item.id}}" placeholder="0" />
              </view>
              <text class="material-subtotal">{{processSubtotals[item.id] || '0.00'}}元</text>
            </view>
          </view>

          <!-- 工序费用合计 + 编辑按钮 -->
          <view class="subtotal-row process-subtotal-row">
            <text>工序费用合计</text>
            <view class="subtotal-right">
              <text class="subtotal-value">{{summaryData.processCost || '0.00'}} 元</text>
              <view class="edit-btn" bindtap="toggleProcessExpand">
                <text>{{processExpanded ? '收起' : '编辑'}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 其他费用 -->
      <view class="section-header">
        <text class="section-title">其他费用</text>
      </view>

      <view class="card">
        <view class="form-item">
          <text class="form-label">制造费用（元）</text>
          <input class="form-input" type="digit" value="{{mfgCost}}" bindinput="onMfgCostInput" />
        </view>
        <view class="fee-row">
          <text class="fee-label">利润（{{profitRate * 100}}%）</text>
          <text class="fee-value">{{summaryData.profit}} 元</text>
        </view>
      </view>

      <!-- 最终报价 -->
      <view class="final-price-card">
        <text class="final-label">最终报价</text>
        <view class="final-value-wrap">
          <text class="final-value">{{summaryData.finalPrice}}</text>
          <text class="final-unit">元</text>
        </view>
      </view>

      <!-- 占位，给底部按钮留空间 -->
      <view class="bottom-placeholder"></view>
    </view>

    <!-- 物流Tab内容 -->
    <view class="panel logistics-panel {{logisticsReadonly ? 'readonly-panel' : ''}}" wx:if="{{mainTab === 'logistics'}}">
      <view class="section-header">
        <text class="section-title">物流运费</text>
      </view>

      <view class="logistics-card">
        <!-- 路线选择 -->
        <view class="route-row">
          <view class="route-box-wrap">
            <text class="route-label">出发地</text>
            <view wx:if="{{logisticsDirection === 'outbound'}}">
              <view class="route-display fixed">柳州</view>
            </view>
            <view wx:else>
              <view class="route-input-row">
                <input class="route-input" placeholder="搜索城市" value="{{originSearchText}}" bindinput="onOriginSearchInput" />
                <picker mode="multiSelector" range="{{originRegionRange}}"
                        value="{{originRegionIndex}}"
                        bindcolumnchange="onOriginColumnChange"
                        bindchange="onOriginRegionChange"
                        class="route-picker-icon">
                  <text class="picker-arrow">▼</text>
                </picker>
              </view>
              <view class="city-suggest-list" wx:if="{{showOriginSuggest && originSearchResults.length > 0}}">
                <view class="city-suggest-item" wx:for="{{originSearchResults}}" wx:key="label" data-idx="{{index}}" bindtap="onSelectOriginSearchCity">{{item.label}}</view>
              </view>
            </view>
          </view>

          <view class="swap-btn" bindtap="swapLocations">
            <text class="swap-icon">⇄</text>
          </view>

          <view class="route-box-wrap">
            <text class="route-label">目的地</text>
            <view wx:if="{{logisticsDirection === 'inbound'}}">
              <view class="route-display fixed">柳州</view>
            </view>
            <view wx:else>
              <view class="route-input-row">
                <input class="route-input" placeholder="搜索城市" value="{{destSearchText}}" bindinput="onDestSearchInput" />
                <picker mode="multiSelector" range="{{destRegionRange}}"
                        value="{{destRegionIndex}}"
                        bindcolumnchange="onDestColumnChange"
                        bindchange="onDestRegionChange"
                        class="route-picker-icon">
                  <text class="picker-arrow">▼</text>
                </picker>
              </view>
              <view class="city-suggest-list" wx:if="{{showDestSuggest && destSearchResults.length > 0}}">
                <view class="city-suggest-item" wx:for="{{destSearchResults}}" wx:key="label" data-idx="{{index}}" bindtap="onSelectDestSearchCity">{{item.label}}</view>
              </view>
            </view>
          </view>
        </view>

        <!-- 总立方数 + 查询按钮 -->
        <view class="query-row">
          <view class="volume-input-wrap">
            <input class="volume-input" type="digit" always-embed placeholder="总立方" value="{{totalVolume}}" bindinput="onTotalVolumeInput" disabled="{{logisticsReadonly}}" />
            <text class="volume-unit">m³</text>
          </view>
          <button class="query-btn" bindtap="queryLogistics" loading="{{logisticsLoading}}" wx:if="{{!logisticsReadonly}}">
            查询运费
          </button>
        </view>

        <!-- 已选方案显示 -->
        <view class="selected-logistics" wx:if="{{selectedLogisticsSummary}}">
          <view class="selected-row">
            <text class="selected-label">已选方案</text>
            <text class="selected-summary">{{selectedLogisticsSummary}}</text>
          </view>
          <view class="selected-row">
            <text class="selected-label">运费合计</text>
            <text class="selected-freight">¥{{freight}}</text>
          </view>
        </view>

        <!-- 实际运费输入 -->
        <view class="form-item">
          <text class="form-label">实际运费（元）{{selectedLogisticsSummary ? '（可修改）' : ''}}</text>
          <input class="form-input" type="digit" always-embed value="{{freight}}" bindinput="onFreightInput" placeholder="输入运费" disabled="{{logisticsReadonly}}" />
        </view>
      </view>

      <!-- ==================== 运输信息区域 ==================== -->
      <view class="section-header">
        <text class="section-title">运输信息</text>
      </view>

      <view class="logistics-card">
        <!-- 交货地 -->
        <view class="form-item">
          <text class="form-label">交货地</text>
          <view class="form-display">{{salesData.deliveryLocation || selectedDestination || '请先在销售Tab填写交货地'}}</view>
        </view>

        <!-- 车辆类型 -->
        <view class="form-item" wx:if="{{selectedVehicleType}}">
          <text class="form-label">车辆类型</text>
          <view class="form-display vehicle-type">{{selectedVehicleType}}</view>
        </view>

        <!-- 运输距离 + 核定载质量 -->
        <view class="transport-row">
          <view class="transport-field">
            <text class="field-label">运输距离</text>
            <view class="input-with-unit">
              <input class="field-input" type="digit" always-embed value="{{transportDistance}}" bindinput="onTransportDistanceInput" placeholder="0" disabled="{{logisticsReadonly}}" />
              <text class="field-unit">km</text>
            </view>
          </view>
          <view class="transport-field">
            <text class="field-label">核定载质量</text>
            <view class="input-with-unit">
              <input class="field-input" type="digit" always-embed value="{{ratedLoad}}" bindinput="onRatedLoadInput" placeholder="0" disabled="{{logisticsReadonly}}" />
              <text class="field-unit">t</text>
            </view>
          </view>
        </view>

        <!-- 货箱规格列表 -->
        <view class="box-spec-section">
          <view class="box-spec-header">
            <text class="box-spec-title">货箱规格</text>
            <view class="add-btn" bindtap="addBoxSpec" wx:if="{{!logisticsReadonly}}">+ 添加</view>
          </view>

          <view class="box-spec-empty" wx:if="{{boxSpecs.length === 0}}">
            <text>暂无货箱，点击添加</text>
          </view>

          <view class="box-spec-item" wx:for="{{boxSpecs}}" wx:key="index">
            <view class="box-spec-item-header">
              <text class="box-spec-idx">货箱 {{index + 1}}</text>
              <view class="box-spec-delete" catchtap="deleteBoxSpec" data-idx="{{index}}" wx:if="{{!logisticsReadonly}}">×</view>
            </view>

            <!-- 长 宽 高 -->
            <view class="box-dim-row">
              <view class="box-dim-field">
                <text class="dim-label">长(mm)</text>
                <input class="dim-input" type="digit" always-embed value="{{item.length}}" bindinput="onBoxSpecInput" data-idx="{{index}}" data-field="length" placeholder="0" disabled="{{logisticsReadonly}}" />
              </view>
              <view class="box-dim-field">
                <text class="dim-label">宽(mm)</text>
                <input class="dim-input" type="digit" always-embed value="{{item.width}}" bindinput="onBoxSpecInput" data-idx="{{index}}" data-field="width" placeholder="0" disabled="{{logisticsReadonly}}" />
              </view>
              <view class="box-dim-field">
                <text class="dim-label">高(mm)</text>
                <input class="dim-input" type="digit" always-embed value="{{item.height}}" bindinput="onBoxSpecInput" data-idx="{{index}}" data-field="height" placeholder="0" disabled="{{logisticsReadonly}}" />
              </view>
            </view>

            <!-- 体积 + 一箱零件数 + 数量 -->
            <view class="box-info-row">
              <view class="box-info-field">
                <text class="dim-label">体积(m³)</text>
                <view class="dim-display">{{item.volume || '--'}}</view>
              </view>
              <view class="box-info-field">
                <text class="dim-label">一箱零件数</text>
                <input class="dim-input" type="number" always-embed value="{{item.partsPerBox}}" bindinput="onBoxSpecInput" data-idx="{{index}}" data-field="partsPerBox" placeholder="0" disabled="{{logisticsReadonly}}" />
              </view>
              <view class="box-info-field">
                <text class="dim-label">数量</text>
                <input class="dim-input" type="number" always-embed value="{{item.quantity}}" bindinput="onBoxSpecInput" data-idx="{{index}}" data-field="quantity" placeholder="1" disabled="{{logisticsReadonly}}" />
              </view>
            </view>
          </view>
        </view>

        <!-- 汇总：零件总数 + 每个零件运输费用 -->
        <view class="transport-summary" wx:if="{{boxSpecs.length > 0}}">
          <view class="summary-row">
            <text class="summary-label">零件总数</text>
            <text class="summary-value">{{totalParts}}</text>
          </view>
          <view class="summary-row">
            <text class="summary-label">运输费用（元）</text>
            <text class="summary-value highlight">{{freight || 0}}</text>
          </view>
          <view class="summary-row">
            <text class="summary-label">每个零件运输费用（元）</text>
            <text class="summary-value highlight">{{perPartFreight || '--'}}</text>
          </view>
        </view>
      </view>

      <!-- ==================== 智能装箱区域 ==================== -->
      <view class="section-header">
        <text class="section-title">智能装箱</text>
      </view>

      <view class="logistics-card">
        <!-- 货物清单 -->
        <view class="cargo-section">
          <view class="cargo-header">
            <text class="cargo-title">货物清单</text>
            <view class="add-btn" bindtap="addCargo">+ 添加货物</view>
          </view>

          <view class="cargo-list" wx:if="{{cargoList.length > 0}}">
            <view class="cargo-item" wx:for="{{cargoList}}" wx:key="index">
              <view class="cargo-row">
                <view class="cargo-field">
                  <text class="field-label">包装类型</text>
                  <picker class="cargo-picker" bindchange="onPackTypeChange" data-idx="{{index}}" range="{{packTypes}}" value="{{packTypes.indexOf(item.packType)}}">
                    <view class="picker-value">{{item.packType}} ▼</view>
                  </picker>
                </view>
                <view class="cargo-field">
                  <text class="field-label">数量</text>
                  <input class="cargo-input" type="number" value="{{item.quantity}}" bindinput="onCargoInput" data-idx="{{index}}" data-field="quantity" placeholder="1" />
                </view>
                <view class="cargo-delete" catchtap="deleteCargo" data-idx="{{index}}">×</view>
              </view>

              <view class="cargo-row">
                <view class="cargo-field">
                  <text class="field-label">长(m)</text>
                  <input class="cargo-input" type="digit" value="{{item.length}}" bindinput="onCargoInput" data-idx="{{index}}" data-field="length" placeholder="长度" />
                </view>
                <view class="cargo-field">
                  <text class="field-label">宽(m)</text>
                  <input class="cargo-input" type="digit" value="{{item.width}}" bindinput="onCargoInput" data-idx="{{index}}" data-field="width" placeholder="宽度" />
                </view>
                <view class="cargo-field">
                  <text class="field-label">高(m)</text>
                  <input class="cargo-input" type="digit" value="{{item.height}}" bindinput="onCargoInput" data-idx="{{index}}" data-field="height" placeholder="高度" />
                </view>
              </view>

              <view class="cargo-row">
                <view class="cargo-field">
                  <text class="field-label">重量(kg)</text>
                  <input class="cargo-input" type="digit" value="{{item.weight}}" bindinput="onCargoInput" data-idx="{{index}}" data-field="weight" placeholder="单件重量" />
                </view>
                <view class="cargo-field">
                  <text class="field-label">包装费(元)</text>
                  <input class="cargo-input" type="digit" value="{{item.packFee}}" bindinput="onCargoInput" data-idx="{{index}}" data-field="packFee" placeholder="0" />
                </view>
                <view class="cargo-field">
                  <text class="field-label">限叠层数</text>
                  <input class="cargo-input" type="number" value="{{item.maxStack}}" bindinput="onCargoInput" data-idx="{{index}}" data-field="maxStack" placeholder="3" />
                </view>
              </view>
            </view>
          </view>

          <view class="cargo-empty" wx:else>
            <text>暂无货物，点击添加</text>
          </view>

          <view class="pack-fee-row" wx:if="{{cargoList.length > 0}}">
            <text>包装费合计</text>
            <text class="pack-fee-value">¥{{totalPackFee}}</text>
          </view>
        </view>

        <!-- 计算装箱按钮 -->
        <button class="calc-packing-btn" bindtap="calcBinPacking" loading="{{binPackingLoading}}" wx:if="{{cargoList.length > 0}}">
          计算装车方案
        </button>

        <!-- 方案列表 -->
        <view class="solution-section" wx:if="{{binPackingSolutions.length > 0}}">
          <view class="solution-header">
            <text class="solution-title">装车方案</text>
          </view>
          <view class="solution-list">
            <view class="solution-item {{currentSolutionIdx === index ? 'active' : ''}}"
              wx:for="{{binPackingSolutions}}" wx:key="index"
              bindtap="selectSolution" data-idx="{{index}}">
              <view class="solution-info">
                <view class="solution-name">
                  {{item.name}}
                  <text class="optimal-tag" wx:if="{{item.isOptimal}}">最优</text>
                  <text class="type-tag {{item.solutionType}}" wx:if="{{item.solutionType === 'MIXED'}}">混合</text>
                  <text class="type-tag {{item.solutionType}}" wx:if="{{item.solutionType === 'SCATTER_ONLY'}}">散货</text>
                </view>
                <view class="solution-desc">{{item.description}}</view>
                <view class="solution-scatter" wx:if="{{item.scatterVolume > 0}}">
                  散货: {{item.scatterVolume}}方 × ¥{{item.scatterUnitPrice}}/方 = ¥{{item.scatterCost}}
                </view>
              </view>
              <view class="solution-cost">¥{{item.totalCost}}</view>
              <view class="solution-actions">
                <view class="solution-edit-btn" catchtap="editSolution" data-idx="{{index}}">编辑</view>
                <view class="solution-3d-btn" catchtap="viewSolution3D" data-idx="{{index}}" wx:if="{{item.trucks.length > 0}}">3D</view>
              </view>
            </view>
          </view>

          <button class="confirm-packing-btn" bindtap="confirmBinPacking">确认使用此方案</button>
        </view>
      </view>

      <!-- 3D预览弹窗 -->
      <view class="modal-mask" wx:if="{{show3DPreview}}" catchtap="close3DPreview">
        <view class="preview-3d-modal" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">3D装车预览</text>
            <view class="modal-close" catchtap="close3DPreview">×</view>
          </view>
          <view class="preview-3d-body">
            <bin-packing-3d id="binPacking3d" trucks="{{currentSolution.trucks}}"></bin-packing-3d>
          </view>
          <view class="preview-3d-footer">
            <view class="preview-info-row">
              <text class="preview-info">{{currentSolution.name}}</text>
              <text class="preview-cost">¥{{currentSolution.totalCost}}</text>
            </view>
            <view class="truck-nav" wx:if="{{currentSolution.trucks.length > 1}}">
              <view class="nav-btn {{current3DTruckIdx <= 0 ? 'disabled' : ''}}" bindtap="prev3DTruck">上一辆</view>
              <text class="nav-info">{{current3DTruckIdx + 1}} / {{currentSolution.trucks.length}}</text>
              <view class="nav-btn {{current3DTruckIdx >= currentSolution.trucks.length - 1 ? 'disabled' : ''}}" bindtap="next3DTruck">下一辆</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 方案编辑弹窗 -->
      <view class="modal-mask" wx:if="{{showEditModal}}" catchtap="closeEditModal">
        <view class="edit-solution-modal" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">编辑装车方案</text>
            <view class="modal-close" catchtap="closeEditModal">×</view>
          </view>
          <view class="edit-modal-body">
            <view class="edit-section">
              <view class="edit-section-title">车辆配置</view>
              <view class="edit-truck-list">
                <view class="edit-truck-item" wx:for="{{editingTrucks}}" wx:key="index">
                  <picker mode="selector" range="{{truckTypeOptions}}" bindchange="onEditTruckType" data-idx="{{index}}">
                    <view class="edit-picker">{{item.truckType}}</view>
                  </picker>
                  <picker mode="selector" range="{{truckStyleOptions}}" bindchange="onEditTruckStyle" data-idx="{{index}}">
                    <view class="edit-picker">{{item.truckStyle}}</view>
                  </picker>
                  <input class="edit-count-input" type="number" value="{{item.count}}" bindinput="onEditTruckCount" data-idx="{{index}}" />
                  <text class="edit-count-unit">辆</text>
                  <view class="edit-delete-btn" catchtap="onDeleteTruck" data-idx="{{index}}" wx:if="{{editingTrucks.length > 1}}">×</view>
                </view>
              </view>
              <view class="edit-add-truck" bindtap="onAddTruck">+ 添加车辆</view>
            </view>
            <view class="edit-section">
              <view class="edit-section-title">散货体积（可选）</view>
              <view class="edit-scatter-row">
                <input class="edit-scatter-input" type="digit" value="{{editingScatterVolume}}" bindinput="onEditScatterVolume" placeholder="留空则自动计算" />
                <text class="edit-scatter-unit">立方米</text>
              </view>
            </view>
            <view class="edit-warning" wx:if="{{editWarning}}">{{editWarning}}</view>
          </view>
          <view class="edit-modal-footer">
            <view class="edit-cancel-btn" bindtap="closeEditModal">取消</view>
            <view class="edit-confirm-btn" bindtap="confirmEditSolution">确认修改</view>
          </view>
        </view>
      </view>

      <!-- 物流方案选择弹窗 -->
      <view class="modal-mask" wx:if="{{showLogisticsModal}}" catchtap="closeLogisticsModal">
        <view class="logistics-modal" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">物流方案选择</text>
            <view class="modal-close" catchtap="closeLogisticsModal">×</view>
          </view>

          <!-- 智能推荐按钮 -->
          <view class="smart-recommend-section">
            <view class="smart-recommend-btn" catchtap="smartRecommend">智能推荐</view>
          </view>

          <!-- 智能推荐结果 -->
          <view class="recommend-section" wx:if="{{showRecommend && recommendPlans.length}}">
            <view class="recommend-header">
              <text class="recommend-title">推荐方案（按价格排序）</text>
              <view class="recommend-collapse" catchtap="collapseRecommend">
                <text>收起</text>
                <text class="collapse-arrow">∧</text>
              </view>
            </view>
            <view class="recommend-item" wx:for="{{recommendPlans}}" wx:key="index" catchtap="selectRecommendPlan" data-idx="{{index}}">
              <view class="recommend-rank">{{index + 1}}</view>
              <view class="recommend-content">
                <view class="recommend-desc">{{item.description}}</view>
                <view class="recommend-detail">{{item.detail}}</view>
              </view>
              <view class="recommend-cost">¥{{item.totalCost}}</view>
              <text class="recommend-tag" wx:if="{{index === 0}}">最优</text>
            </view>
          </view>

          <scroll-view class="logistics-modal-body" scroll-y>
            <!-- 散货区域 -->
            <view class="logistics-section" wx:if="{{scatterOptions.length}}">
              <view class="section-title-row">
                <text class="section-icon">📦</text>
                <text class="section-name">散货运输</text>
                <text class="section-tip">（元/m³）</text>
              </view>

              <view class="option-item-wrap" wx:for="{{scatterOptions}}" wx:key="company">
                <view class="option-item">
                  <view class="option-check {{item.checked ? 'checked' : ''}}" catchtap="onScatterCheck" data-idx="{{index}}">
                    <view class="check-icon">{{item.checked ? '✓' : ''}}</view>
                  </view>
                  <view class="option-main">
                    <text class="option-company">{{item.company}}</text>
                    <text class="option-price">¥{{item.price}}/m³</text>
                    <text class="option-recommend" wx:if="{{index === 0 && !item.checked}}">推荐</text>
                  </view>
                  <!-- 散货立方数选择器：+/- 按钮形式 -->
                  <view class="scatter-qty-selector" wx:if="{{item.checked}}">
                    <view class="qty-btn minus" catchtap="onScatterVolumeMinus" data-idx="{{index}}">-</view>
                    <input class="qty-num" type="digit" value="{{item.volume}}" bindinput="onScatterVolumeInput" data-idx="{{index}}" placeholder="0" />
                    <view class="qty-btn plus" catchtap="onScatterVolumePlus" data-idx="{{index}}">+</view>
                  </view>
                  <view class="option-subtotal-wrap" wx:if="{{item.checked && item.subtotal > 0}}">
                    <text class="subtotal-eq">=</text>
                    <input class="subtotal-input" type="digit" value="{{item.subtotal}}" bindinput="onScatterSubtotalInput" data-idx="{{index}}" />
                  </view>
                </view>
                <!-- 第二行：附加费提示 -->
                <view class="option-extra" wx:if="{{item.surcharge || item.minCharge}}">
                  <text class="extra-text" wx:if="{{item.surcharge}}">+¥{{item.surcharge}}/趟（不满10方）</text>
                  <text class="extra-text" wx:if="{{item.minCharge}}">最低¥{{item.minCharge}}</text>
                </view>
              </view>

              <!-- 各公司备注信息 -->
              <view class="scatter-remarks" wx:if="{{scatterOptions.length}}">
                <view class="remark-item" wx:for="{{scatterOptions}}" wx:key="company" wx:if="{{item.remark}}">
                  <text class="remark-company">{{item.company}}：</text>
                  <text class="remark-text">{{item.remark}}</text>
                </view>
              </view>
            </view>

            <!-- 整车区域 -->
            <view class="logistics-section" wx:if="{{truckGroups.length}}">
              <view class="section-title-row">
                <text class="section-icon">🚛</text>
                <text class="section-name">整车运输</text>
                <text class="section-tip">（元/车）</text>
              </view>

              <view class="truck-group" wx:for="{{truckGroups}}" wx:key="type" wx:for-index="gidx">
                <view class="group-title">{{item.type}}</view>
                <view class="option-item" wx:for="{{item.options}}" wx:key="company" wx:for-index="oidx">
                  <view class="option-check {{item.checked ? 'checked' : ''}}" catchtap="onTruckCheck" data-gidx="{{gidx}}" data-oidx="{{oidx}}">
                    <view class="check-icon">{{item.checked ? '✓' : ''}}</view>
                  </view>
                  <view class="option-info">
                    <text class="option-company">{{item.company}}</text>
                    <text class="option-price">¥{{item.price}}/车</text>
                    <text class="option-recommend" wx:if="{{oidx === 0 && !item.checked}}">推荐</text>
                  </view>
                  <!-- 整车数量选择器：+/- 按钮形式 -->
                  <view class="truck-qty-selector" wx:if="{{item.checked}}">
                    <view class="qty-btn minus" catchtap="onTruckQtyMinus" data-gidx="{{gidx}}" data-oidx="{{oidx}}">-</view>
                    <input class="qty-num" type="number" value="{{item.qty || 1}}" bindinput="onTruckQtyInput" data-gidx="{{gidx}}" data-oidx="{{oidx}}" />
                    <view class="qty-btn plus" catchtap="onTruckQtyPlus" data-gidx="{{gidx}}" data-oidx="{{oidx}}">+</view>
                  </view>
                  <view class="option-subtotal-wrap" wx:if="{{item.checked && item.subtotal > 0}}">
                    <text class="subtotal-eq">=</text>
                    <input class="subtotal-input" type="digit" value="{{item.subtotal}}" bindinput="onTruckSubtotalInput" data-gidx="{{gidx}}" data-oidx="{{oidx}}" />
                  </view>
                </view>
              </view>
            </view>
          </scroll-view>

          <!-- 底部合计和确认 -->
          <view class="modal-footer">
            <view class="total-row">
              <text class="total-label">合计运费</text>
              <text class="total-value">¥{{logisticsTotalFreight}}</text>
            </view>
            <button class="confirm-btn" bindtap="confirmLogistics">确认选择</button>
          </view>
        </view>
      </view>
    </view>

    <!-- ==================== 审批Tab ==================== -->
    <view class="panel approve-panel" wx:if="{{mainTab === 'approve'}}">
      <view class="section-header">
        <text class="section-title">成本汇总</text>
      </view>

      <view class="approve-card">
        <view class="approve-kv">
          <text class="approve-kv-label">材料成本</text>
          <text class="approve-kv-val">¥{{approveData.materialCost}}</text>
        </view>
        <view class="approve-kv">
          <text class="approve-kv-label">制造成本</text>
          <text class="approve-kv-val">¥{{approveData.manufactureCost}}</text>
        </view>
        <view class="approve-kv">
          <text class="approve-kv-label">运费</text>
          <text class="approve-kv-val">¥{{approveData.freight}}</text>
        </view>
        <view class="approve-card-divider"></view>
        <view class="approve-kv">
          <text class="approve-kv-label">现金成本</text>
          <text class="approve-kv-val highlight">¥{{approveData.cashCost}}</text>
        </view>
      </view>

      <!-- 费率输入区域 -->
      <view class="section-header">
        <text class="section-title">费用明细</text>
      </view>
      <view class="approve-card">
        <view class="approve-fee-row">
          <text class="approve-fee-label">管理费</text>
          <view class="approve-fee-inputs">
            <input class="approve-fee-rate" type="digit" placeholder="费率" value="{{approveData.mgmtRate}}" bindinput="onApproveInput" data-field="mgmtRate" />
            <text class="approve-fee-eq">=</text>
            <view class="approve-fee-result">{{approveData.mgmtValue || '--'}}</view>
          </view>
        </view>
        <view class="approve-fee-row">
          <text class="approve-fee-label">三方仓</text>
          <view class="approve-fee-inputs">
            <input class="approve-fee-rate" type="digit" placeholder="费率" value="{{approveData.warehouseRate}}" bindinput="onApproveInput" data-field="warehouseRate" />
            <text class="approve-fee-eq">=</text>
            <view class="approve-fee-result">{{approveData.warehouseValue || '--'}}</view>
          </view>
        </view>
        <view class="approve-fee-row">
          <text class="approve-fee-label">财务费</text>
          <view class="approve-fee-inputs">
            <input class="approve-fee-rate" type="digit" placeholder="费率" value="{{approveData.financeRate}}" bindinput="onApproveInput" data-field="financeRate" />
            <text class="approve-fee-eq">=</text>
            <view class="approve-fee-result">{{approveData.financeValue || '--'}}</view>
          </view>
        </view>
        <view class="approve-fee-row">
          <text class="approve-fee-label">质量费用</text>
          <view class="approve-fee-inputs">
            <input class="approve-fee-rate" type="digit" placeholder="费率" value="{{approveData.qualityRate}}" bindinput="onApproveInput" data-field="qualityRate" />
            <text class="approve-fee-eq">=</text>
            <view class="approve-fee-result">{{approveData.qualityValue || '--'}}</view>
          </view>
        </view>
        <view class="approve-fee-row">
          <text class="approve-fee-label">利润</text>
          <view class="approve-fee-inputs">
            <input class="approve-fee-rate" type="digit" placeholder="费率" value="{{approveData.profitRate}}" bindinput="onApproveInput" data-field="profitRate" />
            <text class="approve-fee-eq">=</text>
            <view class="approve-fee-result">{{approveData.profitValue || '--'}}</view>
          </view>
        </view>
        <view class="approve-card-divider"></view>
        <view class="approve-fee-row">
          <text class="approve-fee-label">模具分摊</text>
          <view class="approve-fee-inputs">
            <input class="approve-fee-single" type="digit" placeholder="输入金额" value="{{approveData.moldShare}}" bindinput="onApproveInput" data-field="moldShare" />
          </view>
        </view>
        <view class="approve-fee-row">
          <text class="approve-fee-label">税率</text>
          <view class="approve-fee-inputs">
            <input class="approve-fee-single" type="digit" placeholder="如 1.13" value="{{approveData.taxRate}}" bindinput="onApproveInput" data-field="taxRate" />
          </view>
        </view>
      </view>

      <!-- 报价结果 -->
      <view class="section-header">
        <text class="section-title">报价结果</text>
      </view>
      <view class="approve-card approve-result-card">
        <view class="approve-result-row">
          <text class="approve-result-label">不含税单价</text>
          <text class="approve-result-val">¥{{approveData.preTax || '--'}}</text>
        </view>
        <view class="approve-result-row main">
          <text class="approve-result-label">含税单价</text>
          <text class="approve-result-val">¥{{approveData.postTax || '--'}}</text>
        </view>
      </view>

      <view class="approve-status" wx:if="{{approveData.approved}}">
        <view class="status-icon">✓</view>
        <text class="status-text">已审批通过</text>
      </view>

      <button class="approve-btn" bindtap="approveQuote" wx:if="{{!approveData.approved && canEditSubmit}}">
        审批通过
      </button>

      <button class="export-btn" bindtap="exportQuote" style="margin-top: 20rpx;">
        <text>导出报价单</text>
      </button>
    </view>
  </scroll-view>

  <!-- 底部操作栏（编辑模式） -->
  <view class="bottom-action-bar">
    <block wx:if="{{canRequestModify}}">
      <button class="action-btn modify-btn" bindtap="requestModification">
        <text>申请修改</text>
      </button>
    </block>
    <block wx:elif="{{canEditSubmit}}">
      <button class="action-btn save-btn" bindtap="saveQuoteDraft" disabled="{{isSaving}}">
        <text>{{isSaving ? '保存中...' : '保存草稿'}}</text>
      </button>
      <button class="action-btn submit-btn" bindtap="submitQuote" disabled="{{isSubmitting}}">
        <text>{{isSubmitting ? '提交中...' : '提交'}}</text>
      </button>
    </block>
  </view>

  </view><!-- 编辑模式容器结束 -->

  <!-- 底部固定导出按钮 -->
  <view class="fixed-bottom" wx:if="{{pageMode === 'edit' && mainTab === 'summary'}}">>
    <button class="export-btn" bindtap="exportQuote">
      <text>导出报价单</text>
    </button>
  </view>

  <!-- 规格选择弹窗 -->
  <view class="spec-modal-mask" wx:if="{{showSpecPicker}}" catchtap="closeSpecPicker">
    <view class="spec-modal-body" catchtap="noop">
      <view class="spec-modal-header">
        <text class="spec-modal-title">选择{{specPickerType === 'collector' ? '集流管' : specPickerType === 'fin' ? '翅片' : '扁管'}}规格</text>
        <view class="spec-modal-close" bindtap="closeSpecPicker">×</view>
      </view>
      <scroll-view class="spec-modal-list" scroll-y>
        <view class="spec-modal-item" wx:for="{{specPickerList}}" wx:key="id" bindtap="onSelectSpec" data-idx="{{index}}">
          <text class="spec-modal-name">{{item.name}}</text>
          <text class="spec-modal-add">添加</text>
        </view>
