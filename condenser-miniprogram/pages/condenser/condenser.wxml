              </block>
              <block wx:else>
                <view class="cp-action-btn quick-add" catchtap="openDeviceTemplateSelector" data-skey="{{sec.key}}" data-dtype="moldFee" data-category="mold" wx:if="{{!prodReadonly}}">+</view>
              </block>
