                      <text class="cp-output-val {{row._formulas[col.key] ? 'has-custom-formula' : ''}}" catchtap="openRowFormulaEditor" data-skey="{{sec.key}}" data-id="{{row.id}}" data-field="{{col.key}}" data-dtype="moldFee">{{row[col.key] || '0'}}</text>
                    </block>
                    <block wx:elif="{{prodEditing && !prodReadonly}}">
                      <input class="cp-input" type="{{col.type === 'number' ? 'digit' : 'text'}}" value="{{row[col.key]}}" bindinput="onCustomProcessInput" bindfocus="onCellFocus" bindblur="onCellBlur" data-skey="{{sec.key}}" data-id="{{row.id}}" data-field="{{col.key}}" data-dtype="moldFee" />
                    </block>
                    <block wx:else>
                      <text>{{row[col.key] || '-'}}</text>
                    </block>
                  </view>
                  <view class="cp-cell cp-cell-action" wx:if="{{prodEditing && !prodReadonly}}">
                    <view class="row-action-btn copy" catchtap="copyRow" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dtype="moldFee">复制</view>
                    <view class="row-action-btn move" catchtap="moveRow" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dir="up" data-dtype="moldFee">↑</view>
                    <view class="row-action-btn move" catchtap="moveRow" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dir="down" data-dtype="moldFee">↓</view>
                    <view class="row-action-btn delete" catchtap="deleteCustomProcess" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dtype="moldFee">删除</view>
                  </view>
                </view>
