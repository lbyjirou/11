                  <view class="energy-card-header-left">
                    <text class="energy-card-collapse-icon">{{row._collapsed ? '▶' : '▼'}}</text>
                    <text class="energy-card-name">{{row.name || '未命名'}}</text>
                  </view>
                  <view class="energy-card-actions" wx:if="{{!prodReadonly}}" catchtap="">
                    <view class="row-action-btn copy" catchtap="copyRow" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dtype="energy">复制</view>
                    <view class="row-action-btn move" catchtap="moveRow" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dir="up" data-dtype="energy">↑</view>
                    <view class="row-action-btn move" catchtap="moveRow" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dir="down" data-dtype="energy">↓</view>
                    <view class="row-action-btn delete" catchtap="deleteCustomProcess" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dtype="energy">删除</view>
                  </view>
