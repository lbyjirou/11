      <view class="modal-mask" wx:if="{{showAddColumnModal}}" catchtap="closeAddColumnModal">
        <view class="cp-modal" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">添加列</text>
            <view class="modal-close" catchtap="closeAddColumnModal">×</view>
          </view>
          <view class="modal-body">
            <view class="form-row">
              <view class="form-item half">
                <text class="form-label">列名称</text>
                <input class="form-input" value="{{newColumnData.label}}" bindinput="onNewColumnInput" data-field="label" placeholder="如：产能、时薪" />
              </view>
              <view class="form-item half">
                <text class="form-label">变量名（公式中引用）</text>
                <input class="form-input" value="{{newColumnData.key}}" bindinput="onNewColumnInput" data-field="key" placeholder="如：capacity、wage" />
              </view>
            </view>
            <view class="form-row">
              <view class="form-item half">
                <text class="form-label">数据类型</text>
                <picker bindchange="onNewColumnTypeChange" range="{{['文本', '数字']}}">
                  <view class="form-input picker-display">{{newColumnData.type === 'text' ? '文本' : '数字'}}</view>
                </picker>
              </view>
              <view class="form-item half">
                <text class="form-label">角色</text>
                <picker bindchange="onNewColumnRoleChange" range="{{['输入(手填)', '输出(计算/手填)']}}">
                  <view class="form-input picker-display">{{newColumnData.role === 'input' ? '输入(手填)' : '输出(计算/手填)'}}</view>
                </picker>
              </view>
            </view>
            <view class="form-item">
              <text class="form-label">单位（可选）</text>
              <input class="form-input" value="{{newColumnData.unit}}" bindinput="onNewColumnInput" data-field="unit" placeholder="如：件/H、元/H、元" />
            </view>
            <view class="form-item" wx:if="{{newColumnData.role === 'output'}}">
              <text class="form-label">公式（可选，留空则手填）</text>
              <input class="form-input" value="{{newColumnData.formula}}" bindinput="onNewColumnInput" data-field="formula" placeholder="如：hourlyWage * workers / capacity" />
              <text class="form-hint">使用同区域其他列的 key 作为变量名</text>
            </view>
          </view>
          <view class="modal-footer">
            <button class="confirm-btn" bindtap="confirmAddColumn">确认</button>
          </view>
        </view>
      </view>

      <!-- 添加工序/能耗弹窗 -->
      <view class="modal-mask" wx:if="{{showCustomProcessModal}}" catchtap="closeCustomProcessModal">
        <view class="cp-modal cp-modal-lg" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">{{editingSubtype === 'material' ? '添加辅料' : editingSubtype === 'device' ? '添加设备消耗' : editingDtype === 'moldFee' ? '添加模具费' : '添加工序'}}</text>
            <view class="modal-header-actions">
              <view class="prod-btn tpl" catchtap="openPresetManager" wx:if="{{editingDtype !== 'energy' && editingDtype !== 'moldFee'}}">预设工序</view>
              <view class="prod-btn tpl" catchtap="openMaterialPresetManager" wx:if="{{editingSubtype === 'material'}}">预设辅料</view>
              <view class="modal-close" catchtap="closeCustomProcessModal">×</view>
            </view>
          </view>
          <view class="modal-body">
            <!-- 名称搜索（带预设下拉，仅工序模式） -->
            <view class="form-item preset-search-wrap" wx:if="{{editingDtype === 'process'}}">
              <text class="form-label">工序名称（可搜索预设/后端工序）</text>
              <input class="form-input" value="{{presetSearchKeyword}}" bindinput="onPresetSearchInput" bindblur="hidePresetDropdown" placeholder="输入工序名称搜索预设" />
              <view class="preset-dropdown" wx:if="{{showPresetDropdown && filteredPresets.length}}">
                <scroll-view scroll-y class="preset-dropdown-scroll">
                  <view class="preset-option {{batchSelectedPresets && batchSelectedPresets.length > 0 && batchSelectedPresets.some ? '' : ''}}" wx:for="{{filteredPresets}}" wx:key="id" catchtap="selectPresetForProcess" data-id="{{item.id}}">
                    <text class="preset-option-name">{{item.name}}</text>
                    <text class="preset-option-section">{{item.sectionLabel}}</text>
                  </view>
                </scroll-view>
              </view>
            </view>
            <!-- 批量已选预设列表 -->
            <view class="batch-preset-list" wx:if="{{batchSelectedPresets.length > 1}}">
              <text class="form-label">已选 {{batchSelectedPresets.length}} 道工序（批量添加）</text>
              <view class="batch-preset-item" wx:for="{{batchSelectedPresets}}" wx:key="id">
                <text class="batch-preset-name">{{item.name}}</text>
                <text class="batch-preset-section">{{item.sectionLabel}}</text>
                <view class="batch-preset-remove" catchtap="removeBatchPreset" data-id="{{item.id}}">×</view>
              </view>
            </view>
            <!-- 目标区域提示 -->
            <view class="preset-target-hint" wx:if="{{customProcessSelectedPreset}}">
              <text>将添加到区域：{{customProcessSelectedPreset.sectionLabel}}</text>
            </view>
            <!-- 列输入（已有区域 - 工序模式，无预设时用区域列） -->
            <block wx:if="{{editingDtype === 'process' && !customProcessSelectedPreset}}" wx:for="{{customProcessData.sections}}" wx:key="key" wx:for-item="sec">
              <block wx:if="{{sec.key === customProcessSectionKey}}">
                <view class="form-item" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col" wx:if="{{col.key !== 'name'}}">
                  <text class="form-label">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}} {{col.role === 'output' && col.formula ? '[自动计算]' : ''}}</text>
                  <view class="cp-formula-result" wx:if="{{col.role === 'output' && col.formula}}">
                    <text>{{customProcessFormData[col.key] || '0'}}</text>
                  </view>
                  <input wx:else class="form-input" type="{{col.type === 'number' ? 'digit' : 'text'}}" value="{{customProcessFormData[col.key]}}" bindinput="onCustomProcessFormInput" data-field="{{col.key}}" placeholder="请输入" />
                </view>
              </block>
            </block>
            <!-- 列输入（设备消耗 - 表格列模式） -->
            <block wx:if="{{editingSubtype === 'device'}}" wx:for="{{customProcessData.energySections}}" wx:key="key" wx:for-item="sec">
              <block wx:if="{{sec.key === customProcessSectionKey}}">
                <view class="form-item" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">
                  <text class="form-label">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}} {{col.role === 'output' && col.formula ? '[自动计算]' : ''}}</text>
                  <block wx:if="{{col.role === 'output' && col.formula}}">
                    <view class="row-formula-input-wrap">
                      <text class="row-formula-prefix">fx</text>
                      <input class="form-input row-formula-input" value="{{customProcessFormFormulas[col.key] || col.formula}}" bindinput="onCustomProcessFormFormulaInput" data-field="{{col.key}}" placeholder="公式" />
                    </view>
                    <view class="cp-formula-result">
                      <text>= {{customProcessFormData[col.key] || '0'}}</text>
                    </view>
                  </block>
                  <input wx:else class="form-input" type="{{col.type === 'number' ? 'digit' : 'text'}}" value="{{customProcessFormData[col.key]}}" bindinput="onCustomProcessFormInput" data-field="{{col.key}}" placeholder="请输入" />
                </view>
              </block>
            </block>
            <!-- 辅料卡片模式表单（简化：搜索选预设 或 手动填值） -->
            <block wx:if="{{editingSubtype === 'material'}}">
              <!-- 物料名称搜索 -->
              <view class="form-item preset-search-wrap">
                <text class="form-label">物料名称</text>
                <input class="form-input" type="text" always-embed bindinput="onEnergyCardNameInput" bindblur="hideEnergyPresetDropdown" placeholder="输入名称搜索预设，或直接填写" />
                <view class="preset-dropdown" wx:if="{{showEnergyPresetDropdown && filteredEnergyPresets.length}}">
                  <scroll-view scroll-y class="preset-dropdown-scroll">
                    <view class="preset-option" wx:for="{{filteredEnergyPresets}}" wx:key="id" wx:for-item="ep" catchtap="selectEnergyCardPreset" data-id="{{ep.id}}">
                      <text class="preset-option-name">{{ep.name}}</text>
                      <text class="preset-option-section">{{ep.params.length}}个变量</text>
                    </view>
                  </scroll-view>
                </view>
              </view>

              <!-- 已选预设提示 + 清除 -->
              <view class="ec-selection-hint" wx:if="{{energyCardParams}}">
                <text class="ec-selection-name">预设：{{energyCardName}}</text>
                <view class="ec-selection-clear" catchtap="clearEnergySelection">清除选择</view>
              </view>

              <!-- 选中预设后：显示变量填值 -->
              <view class="ec-fill-list" wx:if="{{energyCardParams}}">
                <view class="ec-fill-item" wx:for="{{energyCardParams}}" wx:key="_uid" wx:for-item="p">
                  <text class="ec-fill-label">{{p.label || p.key}}{{p.unit ? '(' + p.unit + ')' : ''}}</text>
                  <block wx:if="{{p.role === 'output'}}">
                    <text class="ec-fill-result">= {{energyCardValues[p.key] || '0'}}</text>
                  </block>
                  <block wx:else>
                    <input class="ec-fill-input" always-embed type="{{p.type === 'number' ? 'digit' : 'text'}}" value="{{energyCardValues[p.key]}}" bindinput="onEnergyCardValueInput" data-field="{{p.key}}" placeholder="请输入" />
                  </block>
                </view>
              </view>

              <!-- 未选预设：手动模式 -->
              <block wx:if="{{!energyCardParams}}">
                <view class="form-item">
                  <text class="form-label">金额(元)</text>
                  <input class="form-input" type="digit" always-embed value="{{energyManualAmount}}" bindinput="onEnergyManualAmountInput" placeholder="请输入金额" />
                </view>
                <view class="ec-manual-section">
                  <view class="ec-manual-header">
                    <text class="form-label">自定义参数</text>
                    <view class="ec-param-add-btn" catchtap="addEnergyManualParam">+ 添加参数</view>
                  </view>
                  <view class="ec-manual-row" wx:for="{{energyManualParams}}" wx:key="index">
                    <input class="ec-manual-input label" always-embed value="{{item.label}}" bindinput="onEnergyManualParamInput" data-idx="{{index}}" data-field="label" placeholder="参数名" />
                    <input class="ec-manual-input value" always-embed value="{{item.value}}" bindinput="onEnergyManualParamInput" data-idx="{{index}}" data-field="value" placeholder="值" />
                    <view class="ec-param-del" catchtap="deleteEnergyManualParam" data-idx="{{index}}">×</view>
                  </view>
                </view>
              </block>
            </block>
            <!-- 列输入（已有区域 - 模具费模式，显示所有列） -->
            <block wx:if="{{editingDtype === 'moldFee'}}" wx:for="{{customProcessData.moldFeeSections}}" wx:key="key" wx:for-item="sec">
              <block wx:if="{{sec.key === customProcessSectionKey}}">
                <view class="form-item" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">
                  <text class="form-label">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}} {{col.role === 'output' && col.formula ? '[自动计算]' : ''}}</text>
                  <view class="cp-formula-result" wx:if="{{col.role === 'output' && col.formula}}">
                    <text>{{customProcessFormData[col.key] || '0'}}</text>
                  </view>
                  <input wx:else class="form-input" type="{{col.type === 'number' ? 'digit' : 'text'}}" value="{{customProcessFormData[col.key]}}" bindinput="onCustomProcessFormInput" data-field="{{col.key}}" placeholder="请输入" />
                </view>
              </block>
            </block>
            <!-- 列输入（选了预设时，用预设列定义，含公式） -->
            <block wx:if="{{customProcessSelectedPreset}}">
              <block wx:for="{{customProcessSelectedPreset.columns}}" wx:key="key" wx:for-item="col" wx:if="{{col.key !== 'name'}}">
                <view class="form-item">
                  <text class="form-label">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}} {{col.role === 'output' && col.formula ? '[自动计算]' : ''}}</text>
                  <view class="cp-formula-result" wx:if="{{col.role === 'output' && col.formula}}">
                    <text>{{customProcessFormData[col.key] || '0'}}</text>
                  </view>
                  <input wx:else class="form-input" type="{{col.type === 'number' ? 'digit' : 'text'}}" value="{{customProcessFormData[col.key]}}" bindinput="onCustomProcessFormInput" data-field="{{col.key}}" placeholder="请输入" />
                </view>
              </block>
            </block>
          </view>
          <view class="modal-footer">
            <view class="modal-footer-row" wx:if="{{editingSubtype === 'material'}}">
              <button class="confirm-btn" bindtap="confirmAddEnergyCard">确认添加</button>
            </view>
            <button class="confirm-btn" wx:if="{{editingSubtype !== 'material'}}" bindtap="confirmAddCustomProcess">{{batchSelectedPresets.length > 1 ? '批量添加 ' + batchSelectedPresets.length + ' 道工序' : '确认添加'}}</button>
          </view>
        </view>
      </view>

      <!-- 预设工序管理弹窗 -->
      <view class="modal-mask" wx:if="{{showPresetManager}}" catchtap="closePresetManager">
        <view class="cp-modal cp-modal-preview" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">预设工序</text>
            <view class="modal-close" catchtap="closePresetManager">×</view>
          </view>
          <scroll-view scroll-y class="modal-body" style="max-height:70vh;">
            <!-- 已有预设列表 -->
            <view class="preset-existing" wx:if="{{processPresets.length}}">
              <view class="form-label" style="margin-bottom:12rpx;">已有预设</view>
              <view class="tpl-list">
                <view class="tpl-item" wx:for="{{processPresets}}" wx:key="id">
                  <view style="flex:1;">
                    <text class="tpl-name">{{item.name}}</text>
                    <text class="preset-option-section" style="margin-left:12rpx;">{{item.sectionLabel}}</text>
                  </view>
                  <view class="tpl-action-btn" catchtap="copyPreset" data-id="{{item.id}}">复制</view>
                  <view class="tpl-action-btn" catchtap="editPreset" data-id="{{item.id}}">编辑</view>
                  <view class="tpl-action-btn danger" catchtap="deletePreset" data-id="{{item.id}}">删除</view>
                </view>
              </view>
            </view>

            <!-- 新增/编辑预设表单 -->
            <view class="preset-form-divider">{{editingPresetId ? '编辑预设' : '新增预设'}}<text wx:if="{{editingPresetId}}" class="preset-cancel-edit" catchtap="cancelEditPreset">取消编辑</text></view>
            <view class="form-item">
              <text class="form-label">工序名称</text>
              <input class="form-input" value="{{presetForm.name}}" bindinput="onPresetFormNameInput" placeholder="如：冲压、焊接、喷涂" />
            </view>

            <!-- 所属区域（模糊搜索） -->
            <view class="form-item preset-search-wrap">
              <text class="form-label">所属区域（必填）</text>
              <input class="form-input" value="{{presetSectionSearch}}" bindinput="onPresetSectionSearchInput" bindblur="hidePresetSectionDropdown" placeholder="输入区域名称，搜索已有或新建" />
              <view class="preset-dropdown" wx:if="{{showPresetSectionDropdown && presetFilteredSections.length}}">
                <scroll-view scroll-y class="preset-dropdown-scroll">
                  <view class="preset-option" wx:for="{{presetFilteredSections}}" wx:key="key" catchtap="selectPresetSection" data-key="{{item.key}}">
                    <text class="preset-option-name">{{item.label}}</text>
                    <text class="preset-option-section">{{item.columns.length}}列</text>
                  </view>
                </scroll-view>
              </view>
            </view>
            <!-- 新区域变量名（未匹配已有区域时显示） -->
            <view class="form-item" wx:if="{{presetSectionSearch && !presetSectionMatched}}">
              <text class="form-label">区域变量名（必填，英文标识）</text>
              <input class="form-input" value="{{presetForm.sectionKey}}" bindinput="onPresetSectionKeyInput" placeholder="如：stamping, welding" />
            </view>

            <!-- 列定义编辑器 -->
            <view class="preset-form-divider">列定义</view>
            <view class="cp-col-list">
              <view class="cp-col-item" wx:for="{{presetForm.columns}}" wx:key="key">
                <view class="cp-col-row-top">
                  <view class="cp-col-inputs">
                    <input class="cp-col-input name" value="{{item.label}}" bindinput="onPresetColumnInput" data-idx="{{index}}" data-field="label" placeholder="列名" />
                    <input class="cp-col-input key" value="{{item.key}}" bindinput="onPresetColumnInput" data-idx="{{index}}" data-field="key" placeholder="变量名" disabled="{{item.key === 'name'}}" />
                  </view>
                  <view class="cp-col-btns">
                    <view class="cp-col-btn danger" catchtap="deletePresetColumn" data-idx="{{index}}">×</view>
                  </view>
                </view>
                <view class="cp-col-row-bottom">
                  <picker class="cp-col-picker" bindchange="onPresetColumnRoleChange" data-idx="{{index}}" range="{{['输入', '输出']}}">
                    <view class="cp-col-tag {{item.role === 'output' ? 'output' : 'input'}}">{{item.role === 'output' ? '输出' : '输入'}}</view>
                  </picker>
                  <input class="cp-col-input unit" value="{{item.unit}}" bindinput="onPresetColumnInput" data-idx="{{index}}" data-field="unit" placeholder="单位" />
                  <input wx:if="{{item.role === 'output'}}" class="cp-col-input formula" value="{{item.formula}}" bindinput="onPresetColumnInput" data-idx="{{index}}" data-field="formula" placeholder="公式" />
                  <input wx:if="{{item.role === 'input' && item.key !== 'name'}}" class="cp-col-input" value="{{item.defaultValue}}" bindinput="onPresetColumnInput" data-idx="{{index}}" data-field="defaultValue" placeholder="默认值" />
                </view>
              </view>
            </view>
            <view class="cp-col-add" bindtap="addPresetColumn">+ 添加列</view>
          </scroll-view>
          <view class="modal-footer">
            <button class="confirm-btn" bindtap="confirmPreset">{{editingPresetId ? '保存修改' : '确认预设'}}</button>
          </view>
        </view>
      </view>

      <!-- 预设辅料管理弹窗 -->
      <view class="modal-mask" wx:if="{{showMaterialPresetManager}}" catchtap="closeMaterialPresetManager">
        <view class="cp-modal cp-modal-preview" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">预设辅料</text>
            <view class="modal-close" catchtap="closeMaterialPresetManager">×</view>
          </view>
          <scroll-view scroll-y class="device-preset-scroll">
           <view class="scroll-inner">
            <!-- 已有预设列表 -->
            <view class="preset-existing" wx:if="{{energyMaterialPresets.length}}">
              <view class="form-label" style="margin-bottom:12rpx;">已有预设</view>
              <view class="tpl-list">
                <view class="tpl-item" wx:for="{{energyMaterialPresets}}" wx:key="id">
                  <view style="flex:1;">
                    <text class="tpl-name">{{item.name}}</text>
                    <text class="preset-option-section" style="margin-left:12rpx;">{{item.params.length}}个变量</text>
                  </view>
                  <view class="tpl-action-btn" catchtap="editMaterialPreset" data-id="{{item.id}}">编辑</view>
                  <view class="tpl-action-btn danger" catchtap="deleteMaterialPreset" data-id="{{item.id}}">删除</view>
                </view>
              </view>
            </view>

            <!-- 新增/编辑预设表单 -->
            <view class="preset-form-divider">{{editingMaterialPresetId !== null ? '编辑预设' : '新增预设'}}<text wx:if="{{editingMaterialPresetId !== null}}" class="preset-cancel-edit" catchtap="cancelEditMaterialPreset">取消编辑</text></view>
            <view class="form-item">
              <text class="form-label">预设名称</text>
              <input class="form-input" value="{{materialPresetForm.name}}" bindinput="onMaterialPresetFormInput" data-field="name" placeholder="如：切削液、螺丝" />
            </view>

            <!-- 变量定义编辑器 -->
            <view class="preset-form-divider">变量定义</view>
            <view class="cp-col-list">
              <view class="cp-col-item" wx:for="{{materialPresetForm.params}}" wx:key="index">
                <view class="cp-col-row-top">
                  <view class="cp-col-inputs">
                    <input class="cp-col-input name" value="{{item.label}}" bindinput="onMaterialPresetParamInput" data-idx="{{index}}" data-field="label" placeholder="显示名" />
                    <input class="cp-col-input key" value="{{item.key}}" bindinput="onMaterialPresetParamInput" data-idx="{{index}}" data-field="key" placeholder="变量名" disabled="{{item.key === 'amount'}}" />
                  </view>
                  <view class="cp-col-btns">
                    <view class="cp-col-btn danger" catchtap="deleteMaterialPresetParam" data-idx="{{index}}" wx:if="{{item.key !== 'amount'}}">×</view>
                  </view>
                </view>
                <view class="cp-col-row-bottom">
                  <picker class="cp-col-picker" bindchange="onMaterialPresetParamRoleChange" data-idx="{{index}}" range="{{['输入', '输出']}}">
                    <view class="cp-col-tag {{item.role === 'output' ? 'output' : 'input'}}">{{item.role === 'output' ? '输出' : '输入'}}</view>
                  </picker>
                  <input class="cp-col-input unit" value="{{item.unit}}" bindinput="onMaterialPresetParamInput" data-idx="{{index}}" data-field="unit" placeholder="单位" />
                  <input wx:if="{{item.role === 'output'}}" class="cp-col-input formula" value="{{item.formula}}" bindinput="onMaterialPresetParamInput" data-idx="{{index}}" data-field="formula" placeholder="公式" />
                  <input wx:if="{{item.role !== 'output' && item.key !== 'amount'}}" class="cp-col-input default-val" value="{{item.defaultValue}}" bindinput="onMaterialPresetParamInput" data-idx="{{index}}" data-field="defaultValue" placeholder="默认值" />
                </view>
              </view>
            </view>
            <view class="cp-col-add" bindtap="addMaterialPresetParam">+ 添加变量</view>
           </view>
          </scroll-view>
          <view class="modal-footer">
            <button class="confirm-btn" bindtap="confirmMaterialPreset">{{editingMaterialPresetId !== null ? '保存修改' : '确认预设'}}</button>
          </view>
        </view>
      </view>

      <!-- 设备能耗模版选择弹窗 -->
      <view class="modal-mask" wx:if="{{showDeviceTemplateSelector}}" catchtap="closeDeviceTemplateSelector">
        <view class="cp-modal cp-modal-lg" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">{{templateCategory === 'mold' ? '添加模具费' : '添加设备消耗'}}</text>
            <view class="modal-header-actions">
              <view class="prod-btn tpl" catchtap="openDevicePresetManager">预设</view>
              <view class="modal-close" catchtap="closeDeviceTemplateSelector">×</view>
            </view>
          </view>
          <view class="modal-body">
            <!-- 搜索框（选中后显示模版名，可重新搜索） -->
            <view class="form-item preset-search-wrap">
              <text class="form-label">{{templateCategory === 'mold' ? '工模名称' : '模版名称'}}</text>
              <input class="form-input" value="{{deviceTemplateSearchKeyword}}" bindinput="onDeviceTemplateSearch" bindblur="hideDeviceTemplateDropdown" placeholder="{{templateCategory === 'mold' ? '输入工模名称搜索' : '输入名称搜索模版'}}" />
              <!-- 下拉搜索结果 -->
              <view class="preset-dropdown" wx:if="{{showDeviceTemplateDropdown && deviceTemplateResults.length}}">
                <scroll-view scroll-y class="preset-dropdown-scroll">
                  <view class="preset-option" wx:for="{{deviceTemplateResults}}" wx:key="id" catchtap="selectDeviceTemplate" data-id="{{item.id}}">
                    <text class="preset-option-name">{{item.name}}</text>
                  </view>
                </scroll-view>
              </view>
            </view>
            <view class="cp-empty" wx:if="{{!deviceTemplateResults.length && deviceTemplateSearchKeyword && showDeviceTemplateDropdown}}">
              <text>未找到匹配模版</text>
            </view>

            <!-- 选中模版后：填值表单 -->
            <block wx:if="{{selectedDeviceTemplate}}">
              <!-- 顶层变量 -->
              <block wx:for="{{selectedDeviceTemplate._parsed.variables}}" wx:key="key" wx:for-item="v">
                <view class="form-item">
                  <text class="form-label">{{v.label}}{{v.unit ? '(' + v.unit + ')' : ''}} {{v.role === 'output' && v._displayFormula ? '[' + v._displayFormula + ']' : ''}}</text>
                  <view class="cp-formula-result" wx:if="{{v.role === 'output'}}">
                    <text>= {{deviceCardValues[v.key] || '0'}}</text>
                  </view>
                  <input wx:else class="form-input" type="{{v.type === 'number' ? 'digit' : 'text'}}" value="{{deviceCardValues[v.key]}}" bindinput="onDeviceCardValueInput" data-field="{{v.key}}" placeholder="{{v.defaultValue || '请输入'}}" />
                </view>
              </block>
              <!-- 子区域 -->
              <block wx:for="{{selectedDeviceTemplate._parsed.subGroups}}" wx:key="label" wx:for-item="sg">
                <view class="preset-form-divider">{{sg.label}}</view>
                <block wx:for="{{sg.variables}}" wx:key="key" wx:for-item="v">
                  <view class="form-item">
                    <text class="form-label">{{v.label}}{{v.unit ? '(' + v.unit + ')' : ''}} {{v.role === 'output' && v._displayFormula ? '[' + v._displayFormula + ']' : ''}}</text>
                    <view class="cp-formula-result" wx:if="{{v.role === 'output'}}">
                      <text>= {{deviceCardValues[v.key] || '0'}}</text>
                    </view>
                    <input wx:else class="form-input" type="{{v.type === 'number' ? 'digit' : 'text'}}" value="{{deviceCardValues[v.key]}}" bindinput="onDeviceCardValueInput" data-field="{{v.key}}" placeholder="{{v.defaultValue || '请输入'}}" />
                  </view>
                </block>
              </block>
            </block>
          </view>
          <view class="modal-footer" wx:if="{{selectedDeviceTemplate}}">
            <button class="confirm-btn" bindtap="confirmAddDeviceCard">确认添加</button>
          </view>
        </view>
      </view>

      <!-- 设备能耗预设管理弹窗 -->
      <view class="modal-mask" wx:if="{{showDevicePresetManager}}" catchtap="closeDevicePresetManager">
        <view class="cp-modal cp-modal-preview" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">{{templateCategory === 'mold' ? '模具费预设' : '设备能耗预设'}}</text>
            <view class="modal-close" catchtap="closeDevicePresetManager">×</view>
          </view>
          <scroll-view scroll-y class="device-preset-scroll">
           <view class="scroll-inner">
            <!-- 已有预设列表 -->
            <view class="preset-existing" wx:if="{{devicePresets.length}}">
              <view class="form-label" style="margin-bottom:12rpx;">已有预设</view>
              <view class="tpl-list">
                <view class="tpl-item" wx:for="{{devicePresets}}" wx:key="id">
                  <view style="flex:1;">
                    <text class="tpl-name">{{item.name}}</text>
                  </view>
                  <view class="tpl-action-btn" catchtap="editDevicePreset" data-id="{{item.id}}">编辑</view>
                  <view class="tpl-action-btn danger" catchtap="deleteDevicePreset" data-id="{{item.id}}">删除</view>
                </view>
              </view>
            </view>

            <!-- 新增/编辑表单 -->
            <view class="preset-form-divider">{{editingDevicePresetId ? '编辑预设' : '新增预设'}}<text wx:if="{{editingDevicePresetId}}" class="preset-cancel-edit" catchtap="cancelEditDevicePreset">取消编辑</text></view>
            <view class="form-item">
              <text class="form-label">预设名称</text>
              <input class="form-input" value="{{devicePresetForm.name}}" bindinput="onDevicePresetFormInput" data-field="name" placeholder="{{templateCategory === 'mold' ? '如：冲压模、注塑模' : '如：CNC加工中心、注塑机'}}" />
            </view>

            <!-- 顶层变量 -->
            <view class="preset-form-divider">变量定义</view>
            <view class="cp-col-list">
              <view class="cp-col-item" wx:for="{{devicePresetForm.variables}}" wx:key="index">
                <view class="cp-col-row-top">
                  <view class="cp-col-inputs">
                    <input class="cp-col-input name" value="{{item.label}}" bindinput="onDevicePresetVarInput" data-idx="{{index}}" data-field="label" placeholder="显示名" />
                    <input class="cp-col-input key" value="{{item.key}}" bindinput="onDevicePresetVarInput" data-idx="{{index}}" data-field="key" placeholder="变量名" />
                  </view>
                  <view class="cp-col-btns">
                    <view class="cp-col-btn danger" catchtap="deleteDevicePresetVariable" data-idx="{{index}}">×</view>
                  </view>
                </view>
                <view class="cp-col-row-bottom">
                  <picker class="cp-col-picker" bindchange="onDevicePresetVarRoleChange" data-idx="{{index}}" range="{{['输入', '输出']}}">
                    <view class="cp-col-tag {{item.role === 'output' ? 'output' : 'input'}}">{{item.role === 'output' ? '输出' : '输入'}}</view>
                  </picker>
                  <input class="cp-col-input unit" value="{{item.unit}}" bindinput="onDevicePresetVarInput" data-idx="{{index}}" data-field="unit" placeholder="单位" />
                  <input wx:if="{{item.role === 'output'}}" class="cp-col-input formula" value="{{item.formula}}" bindinput="onDevicePresetVarInput" data-idx="{{index}}" data-field="formula" placeholder="公式" />
                  <input wx:if="{{item.role !== 'output'}}" class="cp-col-input default-val" value="{{item.defaultValue}}" bindinput="onDevicePresetVarInput" data-idx="{{index}}" data-field="defaultValue" placeholder="默认值" />
                </view>
              </view>
            </view>
            <view class="cp-col-add" bindtap="addDevicePresetVariable">+ 添加变量</view>

            <!-- 子区域 -->
            <view class="preset-form-divider">子区域</view>
            <view class="device-subgroup-editor" wx:for="{{devicePresetForm.subGroups}}" wx:key="index" wx:for-item="sg" wx:for-index="sgIndex">
              <view class="device-subgroup-header">
                <input class="form-input" style="flex:1;" value="{{sg.label}}" bindinput="onDevicePresetSubGroupInput" data-sgIdx="{{sgIndex}}" data-field="label" placeholder="子区域名称" />
                <view class="cp-col-btn danger" catchtap="deleteDevicePresetSubGroup" data-sgIdx="{{sgIndex}}">×</view>
              </view>
              <view class="cp-col-list">
                <view class="cp-col-item" wx:for="{{sg.variables}}" wx:key="index" wx:for-item="sv" wx:for-index="vIndex">
                  <view class="cp-col-row-top">
                    <view class="cp-col-inputs">
                      <input class="cp-col-input name" value="{{sv.label}}" bindinput="onDevicePresetSubGroupVarInput" data-sgIdx="{{sgIndex}}" data-vIdx="{{vIndex}}" data-field="label" placeholder="显示名" />
                      <input class="cp-col-input key" value="{{sv.key}}" bindinput="onDevicePresetSubGroupVarInput" data-sgIdx="{{sgIndex}}" data-vIdx="{{vIndex}}" data-field="key" placeholder="变量名" />
                    </view>
                    <view class="cp-col-btns">
                      <view class="cp-col-btn danger" catchtap="deleteDevicePresetSubGroupVar" data-sgIdx="{{sgIndex}}" data-vIdx="{{vIndex}}">×</view>
                    </view>
                  </view>
                    <view class="cp-col-row-bottom">
                    <picker class="cp-col-picker" bindchange="onDevicePresetSubGroupVarRoleChange" data-sgIdx="{{sgIndex}}" data-vIdx="{{vIndex}}" range="{{['输入', '输出']}}">
                      <view class="cp-col-tag {{sv.role === 'output' ? 'output' : 'input'}}">{{sv.role === 'output' ? '输出' : '输入'}}</view>
                    </picker>
                    <input class="cp-col-input unit" value="{{sv.unit}}" bindinput="onDevicePresetSubGroupVarInput" data-sgIdx="{{sgIndex}}" data-vIdx="{{vIndex}}" data-field="unit" placeholder="单位" />
                    <input wx:if="{{sv.role === 'output'}}" class="cp-col-input formula" value="{{sv.formula}}" bindinput="onDevicePresetSubGroupVarInput" data-sgIdx="{{sgIndex}}" data-vIdx="{{vIndex}}" data-field="formula" placeholder="公式" />
                    <input wx:if="{{sv.role !== 'output'}}" class="cp-col-input default-val" value="{{sv.defaultValue}}" bindinput="onDevicePresetSubGroupVarInput" data-sgIdx="{{sgIndex}}" data-vIdx="{{vIndex}}" data-field="defaultValue" placeholder="默认值" />
                  </view>
                </view>
              </view>
              <view class="cp-col-add" bindtap="addDevicePresetSubGroupVar" data-sgIdx="{{sgIndex}}">+ 添加变量</view>
            </view>
            <view class="cp-col-add" bindtap="addDevicePresetSubGroup">+ 添加子区域</view>
           </view>
          </scroll-view>
          <view class="modal-footer">
            <button class="confirm-btn" bindtap="confirmDevicePreset">{{editingDevicePresetId ? '保存修改' : '确认预设'}}</button>
          </view>
        </view>
      </view>

      <!-- 汇总编辑弹窗 -->
      <view class="modal-mask" wx:if="{{showSummaryEditor}}" catchtap="closeSummaryEditor">
        <view class="cp-modal cp-modal-lg" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">编辑汇总项</text>
            <view class="modal-close" catchtap="closeSummaryEditor">×</view>
          </view>
          <view class="modal-body">
            <view class="cp-col-list">
              <view class="cp-col-item" wx:for="{{editingSummary}}" wx:key="key">
                <view class="cp-summary-edit-row">
                  <input class="form-input cp-summary-input" value="{{item.label}}" bindinput="onSummaryItemInput" data-idx="{{index}}" data-field="label" placeholder="名称" />
                  <input class="form-input cp-summary-input" value="{{item.formula}}" bindinput="onSummaryItemInput" data-idx="{{index}}" data-field="formula" placeholder="SUM(区域.列) 或 区域.列[行号]" />
                  <view class="cp-col-btn danger" catchtap="deleteSummaryItem" data-idx="{{index}}">×</view>
                </view>
              </view>
            </view>
            <view class="cp-col-add" bindtap="addSummaryItem">+ 添加汇总项</view>
            <view class="form-hint" style="margin-top:16rpx;">公式支持 SUM(区域key.列key)，如 SUM(s1_xxx.laborCost) + SUM(s2_xxx.machineCost)</view>
          </view>
          <view class="modal-footer">
            <button class="confirm-btn" bindtap="saveSummaryEditor">保存</button>
          </view>
        </view>
      </view>

      <!-- 模版管理弹窗 -->
      <view class="modal-mask" wx:if="{{showTemplateManager}}" catchtap="closeTemplateManager">
        <view class="cp-modal cp-modal-lg" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">模版管理</text>
            <view class="modal-close" catchtap="closeTemplateManager">×</view>
          </view>
          <view class="modal-body">
            <view class="tpl-save-row">
              <input class="form-input" style="flex:1;" value="{{newTemplateName}}" bindinput="onNewTemplateNameInput" placeholder="输入模版名称" />
              <view class="prod-btn add" bindtap="saveCurrentAsTemplate">保存当前为模版</view>
            </view>
            <view class="tpl-list" wx:if="{{processTemplates.length}}">
              <view class="tpl-item" wx:for="{{processTemplates}}" wx:key="id">
                <text class="tpl-name">{{item.name}}</text>
                <view class="tpl-actions">
                  <view class="tpl-action-btn preview" catchtap="openTemplatePreview" data-id="{{item.id}}">预览</view>
                  <view class="tpl-action-btn primary" catchtap="updateTemplateContent" data-id="{{item.id}}" data-name="{{item.name}}">更新</view>
                  <view class="tpl-action-btn" catchtap="renameTemplate" data-id="{{item.id}}" data-name="{{item.name}}">重命名</view>
                  <view class="tpl-action-btn danger" catchtap="deleteTemplate" data-id="{{item.id}}" data-name="{{item.name}}">删除</view>
                </view>
              </view>
            </view>
            <view class="cp-empty" wx:else>
              <text>暂无模版，保存当前结构为模版吧</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 模版预览弹窗 -->
      <view class="modal-mask" wx:if="{{previewTemplateData}}" catchtap="closeTemplatePreview">
        <view class="cp-modal cp-modal-preview" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">模版预览 - {{previewTemplateName}}</text>
            <view class="modal-close" catchtap="closeTemplatePreview">×</view>
          </view>
          <view class="modal-body" style="padding:0;">
            <view class="tpl-pv-section" wx:for="{{previewTemplateData.sections}}" wx:key="key" wx:for-item="sec">
              <view class="tpl-pv-section-header">
                <text class="tpl-pv-section-label">{{sec.label}}</text>
                <text class="tpl-pv-section-key">{{sec.key}}</text>
              </view>
              <scroll-view class="tpl-pv-table-scroll" scroll-x>
                <view class="tpl-pv-table">
                  <view class="tpl-pv-row header">
                    <text class="tpl-pv-cell tpl-pv-cell-no">No.</text>
                    <text class="tpl-pv-cell" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}}</text>
                  </view>
                  <block wx:if="{{sec.rows.length}}">
                    <view class="tpl-pv-row" wx:for="{{sec.rows}}" wx:key="id" wx:for-item="row">
                      <text class="tpl-pv-cell tpl-pv-cell-no">{{index + 1}}</text>
                      <text class="tpl-pv-cell {{col.role === 'output' ? 'output' : ''}}" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">{{row[col.key] !== undefined && row[col.key] !== null && row[col.key] !== '' ? row[col.key] : '-'}}</text>
                    </view>
                  </block>
                  <view class="tpl-pv-row empty" wx:else>
                    <text class="tpl-pv-cell tpl-pv-cell-no">-</text>
                    <text class="tpl-pv-cell" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">-</text>
                  </view>
                </view>
              </scroll-view>
              <view class="tpl-pv-empty" wx:if="{{!sec.rows.length}}">暂无数据</view>
            </view>
            <view class="tpl-pv-energy" wx:if="{{previewTemplateData.energySections.length}}">
              <view class="tpl-pv-group-title">能耗</view>
              <view class="tpl-pv-energy-section" wx:for="{{previewTemplateData.energySections}}" wx:key="key" wx:for-item="sec">
                <view class="tpl-pv-section-header energy">
                  <text class="tpl-pv-section-label">{{sec.label}}</text>
                  <text class="tpl-pv-section-key">{{sec.key}}</text>
                </view>
                <view class="tpl-pv-energy-cards" wx:if="{{sec.rows.length}}">
                  <view class="tpl-pv-energy-card" wx:for="{{sec.rows}}" wx:key="id" wx:for-item="row">
                    <view class="tpl-pv-energy-card-title">{{row.name || '未命名'}}</view>
                    <view class="tpl-pv-energy-grid">
                      <view class="tpl-pv-energy-item" wx:for="{{row.params}}" wx:key="key" wx:for-item="p">
                        <text class="tpl-pv-energy-label">{{p.label}}{{p.unit ? '(' + p.unit + ')' : ''}}</text>
                        <text class="tpl-pv-energy-val">{{row[p.key] !== undefined && row[p.key] !== null && row[p.key] !== '' ? row[p.key] : '-'}}</text>
                      </view>
                    </view>
                    <view class="tpl-pv-energy-sub" wx:for="{{row.subGroups}}" wx:key="label" wx:for-item="sg">
                      <view class="tpl-pv-energy-sub-title">{{sg.label}}</view>
                      <view class="tpl-pv-energy-grid">
                        <view class="tpl-pv-energy-item" wx:for="{{sg.variables}}" wx:key="key" wx:for-item="p">
                          <text class="tpl-pv-energy-label">{{p.label}}{{p.unit ? '(' + p.unit + ')' : ''}}</text>
                          <text class="tpl-pv-energy-val">{{row[p.key] !== undefined && row[p.key] !== null && row[p.key] !== '' ? row[p.key] : '-'}}</text>
                        </view>
                      </view>
                    </view>
                  </view>
                </view>
                <view class="tpl-pv-empty" wx:else>暂无数据</view>
              </view>
            </view>
            <view class="tpl-pv-mold" wx:if="{{previewTemplateData.moldFeeSections.length}}">
              <view class="tpl-pv-group-title">模具费</view>
              <view class="tpl-pv-section" wx:for="{{previewTemplateData.moldFeeSections}}" wx:key="key" wx:for-item="sec">
                <view class="tpl-pv-section-header mold">
                  <text class="tpl-pv-section-label">{{sec.label}}</text>
                  <text class="tpl-pv-section-key">{{sec.key}}</text>
                </view>
                <scroll-view class="tpl-pv-table-scroll" scroll-x>
                  <view class="tpl-pv-table">
                    <view class="tpl-pv-row header">
                      <text class="tpl-pv-cell tpl-pv-cell-no">No.</text>
                      <text class="tpl-pv-cell" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}}</text>
                    </view>
                    <block wx:if="{{sec.rows.length}}">
                      <view class="tpl-pv-row" wx:for="{{sec.rows}}" wx:key="id" wx:for-item="row">
                        <text class="tpl-pv-cell tpl-pv-cell-no">{{index + 1}}</text>
                        <text class="tpl-pv-cell {{col.role === 'output' ? 'output' : ''}}" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">{{row[col.key] !== undefined && row[col.key] !== null && row[col.key] !== '' ? row[col.key] : '-'}}</text>
                      </view>
                    </block>
                    <view class="tpl-pv-row empty" wx:else>
                      <text class="tpl-pv-cell tpl-pv-cell-no">-</text>
                      <text class="tpl-pv-cell" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">-</text>
                    </view>
                  </view>
                </scroll-view>
                <view class="tpl-pv-empty" wx:if="{{!sec.rows.length}}">暂无数据</view>
              </view>
            </view>
            <view class="tpl-pv-summary" wx:if="{{previewTemplateData.summary.length}}">
              <view class="tpl-pv-summary-title">汇总</view>
              <view class="tpl-pv-summary-grid">
                <view class="tpl-pv-summary-item" wx:for="{{previewTemplateData.summary}}" wx:key="key">
                  <text class="tpl-pv-summary-label">{{item.label}}</text>
                  <text class="tpl-pv-summary-formula">{{item.value !== undefined && item.value !== null && item.value !== '' ? item.value : (item.formula || '-')}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 运用模版弹窗 -->
      <view class="modal-mask" wx:if="{{showApplyTemplate}}" catchtap="closeApplyTemplate">
        <view class="cp-modal" catchtap="noop">
          <view class="modal-header">
            <text class="modal-title">运用模版</text>
            <view class="modal-close" catchtap="closeApplyTemplate">×</view>
          </view>
          <view class="modal-body">
            <view class="tpl-list" wx:if="{{processTemplates.length}}">
              <view class="tpl-item" wx:for="{{processTemplates}}" wx:key="id">
                <text class="tpl-name">{{item.name}}</text>
                <view class="tpl-actions">
                  <view class="tpl-action-btn primary" catchtap="applyTemplate" data-id="{{item.id}}">运用</view>
                </view>
              </view>
            </view>
            <view class="cp-empty" wx:else>
              <text>暂无模版，请先在"编辑模版"中保存</text>
            </view>
          </view>
        </view>
      </view>

    </view>

    <!-- ==================== 自定义规格 - 集流管 ==================== -->
    <view class="panel" wx:if="{{mainTab === 'custom' && calcSubTab === 'collector'}}">
      <view class="card">
        <view class="card-header">
          <text class="card-title">规格名称</text>
        </view>
        <view class="form-item spec-name-row">
          <picker class="spec-name-picker" bindchange="onCollectorPresetChange" value="{{collectorPresetIndex}}" range="{{collectorPresetNames}}">
            <view class="spec-name-picker-btn">选择</view>
          </picker>
          <input class="form-input flex-input" value="{{collectorSpecName}}" bindinput="onCollectorSpecNameInput" placeholder="输入或选择规格名称" />
        </view>
      </view>

      <view class="card">
        <view class="card-header">
          <text class="card-title">尺寸参数</text>
        </view>
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">截面积（mm²）</text>
            <input class="form-input" type="digit" value="{{collectorArea}}" bindinput="onCollectorAreaInput" />
          </view>
          <view class="form-item half">
            <text class="form-label">长度（mm）</text>
            <input class="form-input" type="digit" value="{{collectorLen}}" bindinput="onCollectorLenInput" />
          </view>
        </view>
      </view>

      <view class="card">
        <view class="card-header">
          <text class="card-title">加工费用</text>
        </view>
        <view class="form-item">
          <text class="form-label">加工费（元）</text>
          <input class="form-input" type="digit" value="{{collectorFee}}" bindinput="onCollectorFeeInput" />
        </view>
      </view>

      <button class="calc-btn {{isCalculating ? 'loading' : ''}}" bindtap="calcCollector" disabled="{{isCalculating}}">
        <view class="btn-loading" wx:if="{{isCalculating}}"></view>
        <text>{{isCalculating ? '计算中' : '计算'}}</text>
      </button>

      <view class="result-card" wx:if="{{collectorResult.weight > 0}}">
        <view class="result-item">
          <text class="result-value">{{collectorResult.weight}}</text>
          <text class="result-label">单根重量</text>
          <text class="result-unit">kg</text>
        </view>
        <view class="result-divider"></view>
        <view class="result-item">
          <text class="result-value">{{collectorResult.unitPrice}}</text>
          <text class="result-label">单根价格</text>
          <text class="result-unit">元</text>
        </view>
      </view>

      <view class="spec-btn-row" wx:if="{{collectorResult.weight > 0}}">
        <button class="save-spec-btn flex-btn" bindtap="saveCollectorSpec">
          {{collectorPresetIndex > 0 ? '更新到规格库' : '添加到规格库'}}
        </button>
        <button class="delete-spec-btn" wx:if="{{collectorPresetIndex > 0}}" bindtap="deleteCollectorSpec">删除规格</button>
      </view>
    </view>

    <!-- ==================== 自定义规格 - 翅片 ==================== -->
    <view class="panel" wx:if="{{mainTab === 'custom' && calcSubTab === 'fin'}}">
      <view class="card">
        <view class="card-header">
          <text class="card-title">规格名称</text>
        </view>
        <view class="form-item spec-name-row">
          <picker class="spec-name-picker" bindchange="onFinPresetChange" value="{{finPresetIndex}}" range="{{finPresetNames}}">
            <view class="spec-name-picker-btn">选择</view>
          </picker>
          <input class="form-input flex-input" value="{{finSpecName}}" bindinput="onFinSpecNameInput" placeholder="输入或选择规格名称" />
        </view>
