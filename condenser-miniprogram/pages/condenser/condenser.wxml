          </view>
          <view class="cp-grand-total-detail">
            <text class="cp-grand-detail-item">工序: ¥{{processAreaTotal || '0'}}</text>
            <text class="cp-grand-detail-item">能耗: ¥{{energyAreaTotal || '0'}}</text>
