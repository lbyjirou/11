        <block wx:if="{{specPickerType === 'tube'}}">
          <view class="spec-modal-item zinc" wx:for="{{specPickerList}}" wx:key="id" bindtap="onSelectSpec" data-idx="{{index}}" data-is-zinc="true">
            <text class="spec-modal-name">{{item.name}}(喷锌)</text>
