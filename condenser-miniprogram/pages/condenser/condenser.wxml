                  <text class="cp-cell cp-cell-no">No.</text>
                  <text class="cp-cell" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}}<text wx:if="{{prodEditing && !prodReadonly}}" class="cp-coord-hint">{{col.key}}</text></text>
