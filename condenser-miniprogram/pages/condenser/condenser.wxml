<view class="page-container">
  <!-- 自定义导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <view class="back-arrow"></view>
    </view>
    <text class="nav-title">冷凝器报价</text>
    <view class="nav-bell" bindtap="onOpenNotifications">
      <text>🔔</text>
      <view class="bell-badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
    </view>
  </view>

  <!-- ==================== 列表模式 ==================== -->
  <view wx:if="{{pageMode === 'list'}}" class="quote-list-container">
    <view class="quote-list-header">
      <text class="quote-list-title">报价单列表</text>
      <view class="create-quote-btn" bindtap="createNewQuote" wx:if="{{userRole === 'SALES' || userRole === 'ADMIN'}}">
        <text>+ 新建</text>
      </view>
    </view>

    <view class="quote-list-loading" wx:if="{{quoteListLoading}}">
      <text>加载中...</text>
    </view>

    <view class="quote-list-empty" wx:elif="{{!quoteList.length}}">
      <text>暂无报价单</text>
    </view>

    <scroll-view class="quote-list" scroll-y wx:else>
      <view class="quote-item {{item.overdue ? 'overdue' : ''}}" wx:for="{{quoteList}}" wx:key="id" bindtap="selectQuote" data-id="{{item.id}}">
        <view class="quote-item-header">
          <text class="quote-no">{{item.quoteNo || '草稿'}}</text>
          <view class="quote-status-group">
            <text class="overdue-tag" wx:if="{{item.overdue}}">超期</text>
            <text class="modification-tag" wx:if="{{item.isInModification}}">修改中</text>
            <text class="quote-status status-{{item.status}}">{{item.statusText}}</text>
          </view>
        </view>
        <view class="quote-item-body">
          <text class="quote-customer">{{item.customerName || '未填写客户'}}</text>
          <text class="quote-project">{{item.projectName || item.partName || ''}}</text>
        </view>
        <view class="quote-item-footer">
          <text class="quote-time">{{item.createTime}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 通知面板（底部半屏） -->
  <view class="customer-overlay" wx:if="{{showNotificationPanel}}" catchtap="onCloseNotifications">
    <view class="customer-sheet" catchtap="">
      <view class="customer-sheet-header">
        <text class="customer-sheet-title">系统通知</text>
        <view class="customer-sheet-add" catchtap="onMarkAllRead" wx:if="{{notifications.length > 0}}">全部已读</view>
        <view class="customer-sheet-close" catchtap="onCloseNotifications">✕</view>
      </view>
      <scroll-view class="customer-sheet-list" scroll-y>
        <view class="customer-list-empty" wx:if="{{notifications.length === 0}}">
          <text>暂无通知</text>
        </view>
        <view class="notification-item {{item.isRead ? 'read' : ''}}" wx:for="{{notifications}}" wx:key="id" catchtap="onNotificationTap" data-item="{{item}}">
          <view class="notification-title">
            <text class="notification-type {{item.type === 'OVERDUE_ESCALATION' ? 'escalation' : item.type === 'DEADLINE_WARNING' ? 'warning' : ''}}">{{item.type === 'OVERDUE_ESCALATION' ? '升级' : item.type === 'DEADLINE_WARNING' ? '预警' : '超期'}}</text>
            <text>{{item.title}}</text>
          </view>
          <text class="notification-msg">{{item.message}}</text>
          <text class="notification-time">{{item.createTime}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- ==================== 编辑模式 ==================== -->
  <view wx:if="{{pageMode === 'edit'}}" class="edit-mode-container">
    <!-- 一级Tab（权限过滤）+ 退出按钮 -->
    <view class="main-tabs-wrapper">
      <view class="main-tabs">
        <view wx:for="{{visibleTabs}}" wx:key="key"
          class="main-tab {{mainTab === item.key ? 'active' : ''}}"
          bindtap="switchMainTab" data-tab="{{item.key}}">
          <text>{{item.label}}</text>
        </view>
      </view>
      <view class="exit-btn" bindtap="exitEditMode">
        <text>退出</text>
      </view>
    </view>

    <!-- 流程进度条 -->
    <view class="progress-bar" wx:if="{{orderProgress && orderProgress.stages}}">
      <view class="modification-banner" wx:if="{{isInModification}}">
        <text>修改流程进行中</text>
      </view>
      <view class="progress-stages">
        <block wx:for="{{orderProgress.stages}}" wx:key="stage">
          <view class="progress-stage {{item.state}}">
            <view class="stage-dot">
              <text wx:if="{{item.state === 'completed'}}">✓</text>
              <text wx:elif="{{item.state === 'current'}}">●</text>
              <text wx:else>○</text>
            </view>
            <text class="stage-label">{{item.stageName}}</text>
          </view>
          <view class="stage-line {{item.state === 'completed' ? 'completed' : ''}}" wx:if="{{index < orderProgress.stages.length - 1}}"></view>
        </block>
      </view>
    </view>

    <!-- 当前环节截止时间提示 -->
    <view class="deadline-banner {{currentStageOverdue ? 'overdue' : ''}}" wx:if="{{currentStageDeadline}}">
      <text wx:if="{{currentStageOverdue}}">当前环节已超时！{{currentStageDeadline}}（{{deadlineRemaining}}）</text>
      <text wx:else>当前环节: {{currentStageDeadline}}（剩余{{deadlineRemaining}}）</text>
    </view>

    <!-- 二级Tab（仅自定义规格页显示） -->
    <view class="sub-tabs" wx:if="{{mainTab === 'custom'}}">
      <view class="sub-tab {{calcSubTab === 'collector' ? 'active' : ''}}" bindtap="switchCalcSubTab" data-tab="collector">集流管</view>
      <view class="sub-tab {{calcSubTab === 'fin' ? 'active' : ''}}" bindtap="switchCalcSubTab" data-tab="fin">翅片</view>
      <view class="sub-tab {{calcSubTab === 'tube' ? 'active' : ''}}" bindtap="switchCalcSubTab" data-tab="tube">扁管</view>
    </view>

    <!-- 内容区域 -->
    <scroll-view class="content-area has-bottom-bar" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- ==================== 设置页 ==================== -->
    <view class="panel" wx:if="{{mainTab === 'setting'}}">
      <view class="card">
        <view class="card-header">
          <text class="card-title">铝价参数</text>
        </view>
        <view class="form-item">
          <text class="form-label">当日铝锭价（元/KG）</text>
          <input class="form-input {{settingReadonly ? 'readonly' : ''}}" type="digit" value="{{alPrice}}" bindinput="onAlPriceInput" placeholder="请输入铝价" disabled="{{settingReadonly}}" />
        </view>
        <button class="save-config-btn" bindtap="saveConfig" wx:if="{{!settingReadonly}}">保存配置</button>
      </view>

      <view class="card">
        <view class="card-header">
          <text class="card-title">数据来源</text>
        </view>
        <view class="info-item" bindtap="copyAlPriceLink">
          <text class="info-text">长江有色金属网</text>
          <text class="info-link">点击复制链接</text>
        </view>
        <view class="current-price">
          <text class="price-label">当前铝价</text>
          <text class="price-value">{{alPrice}}</text>
          <text class="price-unit">元/KG</text>
        </view>
      </view>
    </view>

    <!-- ==================== 销售Tab ==================== -->
    <view class="panel" wx:if="{{mainTab === 'sales'}}">
      <view class="card">
        <view class="card-header"><text class="card-title">报价信息</text></view>
        <!-- RFQ_ID | Quote_ID -->
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">客户RFQ编号</text>
            <input class="form-input {{salesReadonly ? 'readonly' : ''}}" value="{{salesData.rfqId}}" bindinput="onSalesInput" data-field="rfqId" placeholder="请输入" disabled="{{salesReadonly}}" />
          </view>
          <view class="form-item half">
            <text class="form-label">内部报价编号</text>
            <input class="form-input {{salesReadonly ? 'readonly' : ''}}" value="{{salesData.quoteId}}" bindinput="onSalesInput" data-field="quoteId" placeholder="请输入" disabled="{{salesReadonly}}" />
          </view>
        </view>
        <!-- Quote_Version | Status -->
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">报价版本</text>
            <input class="form-input {{salesReadonly ? 'readonly' : ''}}" value="{{salesData.quoteVersion}}" bindinput="onSalesInput" data-field="quoteVersion" placeholder="V0" disabled="{{salesReadonly}}" />
          </view>
          <view class="form-item half">
            <text class="form-label">商业状态</text>
            <picker range="{{commercialStatusOptions}}" range-key="label" value="{{commercialStatusIndex}}" bindchange="onCommercialStatusChange" disabled="{{salesReadonly}}">
              <view class="form-input picker-text {{salesReadonly ? 'readonly' : ''}}">{{commercialStatusOptions[commercialStatusIndex].label || '选择'}}</view>
            </picker>
          </view>
        </view>
        <!-- Owner -->
        <view class="form-item">
          <text class="form-label">报价负责人</text>
          <input class="form-input {{salesReadonly ? 'readonly' : ''}}" value="{{salesData.owner}}" bindinput="onSalesInput" data-field="owner" placeholder="请输入负责人" disabled="{{salesReadonly}}" />
        </view>
        <!-- Customer | OEM_Tier -->
        <view class="form-row">
          <view class="form-item half customer-name-wrapper">
            <text class="form-label">客户名称</text>
            <view class="input-with-icon">
              <input class="form-input flex-input {{salesReadonly ? 'readonly' : ''}}" value="{{salesData.customerName}}" bindinput="onCustomerNameInput" bindblur="onCustomerNameBlur" placeholder="请输入客户名称" disabled="{{salesReadonly}}" />
              <view class="search-icon" catchtap="onOpenCustomerSearch" wx:if="{{!salesReadonly}}">🔍</view>
            </view>
            <!-- 输入联想下拉 -->
            <view class="customer-dropdown" wx:if="{{showCustomerDropdown && customerSuggestions.length > 0}}">
              <view class="customer-dropdown-item" wx:for="{{customerSuggestions}}" wx:key="id" catchtap="onSelectCustomerSuggestion" data-index="{{index}}">
                <text class="customer-dropdown-name">{{item.name}}</text>
                <text class="customer-dropdown-tag" wx:if="{{item.oemTier}}">{{item.oemTier}}</text>
              </view>
            </view>
          </view>
          <view class="form-item half">
            <text class="form-label">OEM层级</text>
            <picker range="{{oemTierOptions}}" value="{{oemTierOptions.indexOf(salesData.oemTier)}}" bindchange="onOemTierChange" disabled="{{salesReadonly}}">
              <view class="form-input picker-text {{salesReadonly ? 'readonly' : ''}}">{{salesData.oemTier || '选择'}}</view>
            </picker>
          </view>
        </view>
        <!-- Vehicle_Project -->
        <view class="form-item">
          <text class="form-label">车型/项目代号</text>
          <input class="form-input {{salesReadonly ? 'readonly' : ''}}" value="{{salesData.vehicleProject}}" bindinput="onSalesInput" data-field="vehicleProject" placeholder="请输入" disabled="{{salesReadonly}}" />
        </view>
        <!-- SOP_Date | EOP_Date -->
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">SOP日期</text>
            <picker mode="date" value="{{salesData.sopDate}}" bindchange="onSalesDateInput" data-field="sopDate" disabled="{{salesReadonly}}">
              <view class="form-input picker-text {{salesReadonly ? 'readonly' : ''}}">{{salesData.sopDate || '选择日期'}}</view>
            </picker>
          </view>
          <view class="form-item half">
            <text class="form-label">EOP日期</text>
            <picker mode="date" value="{{salesData.eopDate}}" bindchange="onSalesDateInput" data-field="eopDate" disabled="{{salesReadonly}}">
              <view class="form-input picker-text {{salesReadonly ? 'readonly' : ''}}">{{salesData.eopDate || '选择日期'}}</view>
            </picker>
          </view>
        </view>
        <!-- Currency | Incoterm -->
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">币种</text>
            <picker range="{{currencyOptions}}" value="{{currencyOptions.indexOf(salesData.currency)}}" bindchange="onCurrencyChange" disabled="{{salesReadonly}}">
              <view class="form-input picker-text {{salesReadonly ? 'readonly' : ''}}">{{salesData.currency || '选择'}}</view>
            </picker>
          </view>
          <view class="form-item half">
            <text class="form-label">贸易条款</text>
            <picker range="{{incotermOptions}}" value="{{incotermOptions.indexOf(salesData.incoterm)}}" bindchange="onIncotermChange" disabled="{{salesReadonly}}">
              <view class="form-input picker-text {{salesReadonly ? 'readonly' : ''}}">{{salesData.incoterm || '选择'}}</view>
            </picker>
          </view>
        </view>
        <!-- Delivery_Location -->
        <view class="form-item">
          <text class="form-label">交货地点</text>
          <input class="form-input {{salesReadonly ? 'readonly' : ''}}" value="{{salesData.deliveryLocation}}" bindinput="onSalesInput" data-field="deliveryLocation" placeholder="请输入交货地点" disabled="{{salesReadonly}}" />
        </view>
        <!-- Valid_Until -->
        <view class="form-item">
          <text class="form-label">报价有效期</text>
          <picker mode="date" value="{{salesData.validUntil}}" bindchange="onSalesDateInput" data-field="validUntil" disabled="{{salesReadonly}}">
            <view class="form-input picker-text {{salesReadonly ? 'readonly' : ''}}">{{salesData.validUntil || '选择日期'}}</view>
          </picker>
        </view>
      </view>

      <!-- Annual_Volume -->
      <view class="card">
        <view class="card-header"><text class="card-title">年需求量</text></view>
        <view class="form-row">
          <view class="form-item third">
            <text class="form-label">第1年</text>
            <input class="form-input {{salesReadonly ? 'readonly' : ''}}" type="number" value="{{salesData.annualVolume1y}}" bindinput="onSalesInput" data-field="annualVolume1y" placeholder="件数" disabled="{{salesReadonly}}" />
          </view>
          <view class="form-item third">
            <text class="form-label">第3年</text>
            <input class="form-input {{salesReadonly ? 'readonly' : ''}}" type="number" value="{{salesData.annualVolume3y}}" bindinput="onSalesInput" data-field="annualVolume3y" placeholder="件数" disabled="{{salesReadonly}}" />
          </view>
          <view class="form-item third">
            <text class="form-label">峰值</text>
            <input class="form-input {{salesReadonly ? 'readonly' : ''}}" type="number" value="{{salesData.annualVolumePeak}}" bindinput="onSalesInput" data-field="annualVolumePeak" placeholder="件数" disabled="{{salesReadonly}}" />
          </view>
        </view>
        <!-- Ramp_Profile -->
        <view class="form-item">
          <text class="form-label">爬坡计划</text>
          <input class="form-input {{salesReadonly ? 'readonly' : ''}}" value="{{salesData.rampProfile}}" bindinput="onSalesInput" data-field="rampProfile" placeholder="月度/季度爬坡说明" disabled="{{salesReadonly}}" />
        </view>
      </view>

      <!-- 模具费用分摊 -->
      <view class="card">
        <view class="card-header"><text class="card-title">模具费用分摊</text></view>
        <view class="form-item">
          <text class="form-label">模具费支付方式</text>
          <view class="radio-group-row">
            <view class="radio-option {{!salesData.moldShared ? 'active' : ''}}" bindtap="onMoldPaymentChange" data-mode="nre">
              <view class="radio-dot {{!salesData.moldShared ? 'checked' : ''}}"></view>
              <text>客户一次性支付</text>
            </view>
            <view class="radio-option {{salesData.moldShared ? 'active' : ''}}" bindtap="onMoldPaymentChange" data-mode="amortized">
              <view class="radio-dot {{salesData.moldShared ? 'checked' : ''}}"></view>
              <text>分摊进零件单价</text>
            </view>
          </view>
        </view>
        <view class="form-item" wx:if="{{salesData.moldShared}}">
          <text class="form-label">分摊数量基数</text>
          <input class="form-input {{salesReadonly ? 'readonly' : ''}}" type="number" value="{{salesData.moldSharedQty}}" bindinput="onSalesInput" data-field="moldSharedQty" placeholder="如：200000件" disabled="{{salesReadonly}}" />
        </view>
        <view class="mold-hint" wx:if="{{!salesData.moldShared}}">
          <text class="hint-text">模具费由客户直接支付，不计入零件单价</text>
        </view>
        <view class="mold-hint" wx:if="{{salesData.moldShared}}">
          <text class="hint-text">模具费将按分摊数量均摊至每件零件单价中</text>
        </view>
      </view>

      <!-- 交期分配 -->
      <view class="card">
        <view class="card-header"><text class="card-title">交期分配</text></view>
        <view class="form-item">
          <text class="form-label">分配模式</text>
          <picker bindchange="onDeadlineModeChange" range="{{['按百分比分配', '按固定天数']}}" disabled="{{salesReadonly}}">
            <view class="form-input picker-text {{salesReadonly ? 'readonly' : ''}}">{{salesData.deadlineMode === 'FIXED_DAYS' ? '按固定天数' : '按百分比分配'}}</view>
          </picker>
        </view>
        <view class="dl-stage-list">
          <view class="dl-stage-item">
            <text class="dl-stage-label">技术</text>
            <input class="dl-stage-input {{salesReadonly ? 'readonly' : ''}}" type="number" value="{{salesData.deadlineTech}}" bindinput="onSalesInput" data-field="deadlineTech" disabled="{{salesReadonly}}" />
            <text class="dl-stage-unit">{{salesData.deadlineMode === 'FIXED_DAYS' ? '天' : '%'}}</text>
          </view>
          <view class="dl-stage-item">
            <text class="dl-stage-label">生产</text>
            <input class="dl-stage-input {{salesReadonly ? 'readonly' : ''}}" type="number" value="{{salesData.deadlineProcess}}" bindinput="onSalesInput" data-field="deadlineProcess" disabled="{{salesReadonly}}" />
            <text class="dl-stage-unit">{{salesData.deadlineMode === 'FIXED_DAYS' ? '天' : '%'}}</text>
          </view>
          <view class="dl-stage-item">
            <text class="dl-stage-label">物流</text>
            <input class="dl-stage-input {{salesReadonly ? 'readonly' : ''}}" type="number" value="{{salesData.deadlineLogistics}}" bindinput="onSalesInput" data-field="deadlineLogistics" disabled="{{salesReadonly}}" />
            <text class="dl-stage-unit">{{salesData.deadlineMode === 'FIXED_DAYS' ? '天' : '%'}}</text>
          </view>
          <view class="dl-stage-item">
            <text class="dl-stage-label">审批</text>
            <input class="dl-stage-input {{salesReadonly ? 'readonly' : ''}}" type="number" value="{{salesData.deadlineApprove}}" bindinput="onSalesInput" data-field="deadlineApprove" disabled="{{salesReadonly}}" />
            <text class="dl-stage-unit">{{salesData.deadlineMode === 'FIXED_DAYS' ? '天' : '%'}}</text>
          </view>
        </view>
        <view class="dl-total-hint" wx:if="{{salesData.deadlineMode !== 'FIXED_DAYS'}}">
          <text class="hint-text">合计: {{(salesData.deadlineTech*1 || 0) + (salesData.deadlineProcess*1 || 0) + (salesData.deadlineLogistics*1 || 0) + (salesData.deadlineApprove*1 || 0)}}%{{(salesData.deadlineTech*1 || 0) + (salesData.deadlineProcess*1 || 0) + (salesData.deadlineLogistics*1 || 0) + (salesData.deadlineApprove*1 || 0) !== 100 ? '（建议合计100%）' : ''}}</text>
        </view>
        <view class="dl-total-hint" wx:if="{{salesData.deadlineMode === 'FIXED_DAYS'}}">
          <text class="hint-text">合计: {{(salesData.deadlineTech*1 || 0) + (salesData.deadlineProcess*1 || 0) + (salesData.deadlineLogistics*1 || 0) + (salesData.deadlineApprove*1 || 0)}} 天</text>
        </view>
      </view>

      <!-- 客户模糊搜索面板（底部半屏） -->
      <view class="customer-overlay" wx:if="{{showCustomerPanel}}" catchtap="onCloseCustomerPanel">
        <view class="customer-sheet" catchtap="">
          <view class="customer-sheet-header">
            <text class="customer-sheet-title">客户搜索</text>
            <view class="customer-sheet-add" catchtap="onShowAddCustomer">+ 新增</view>
            <view class="customer-sheet-close" catchtap="onCloseCustomerPanel">✕</view>
          </view>
          <view class="customer-search-bar">
            <input class="customer-search-input" value="{{customerKeyword}}" bindinput="onCustomerKeywordInput" placeholder="输入客户名称或编码模糊搜索" focus="{{showCustomerPanel}}" />
          </view>
          <scroll-view class="customer-sheet-list" scroll-y>
            <view class="customer-list-empty" wx:if="{{customerSearchResults.length === 0}}">
              <text>未找到匹配客户，可点击「+ 新增客户」</text>
            </view>
            <view class="customer-list-item" wx:for="{{customerSearchResults}}" wx:key="id">
              <view class="customer-list-main" catchtap="onSelectCustomer" data-index="{{index}}">
                <text class="customer-list-name">{{item.name}}</text>
                <view class="customer-list-info">
                  <text wx:if="{{item.code}}" class="customer-list-code">{{item.code}}</text>
                  <text wx:if="{{item.oemTier}}" class="customer-list-tier">{{item.oemTier}}</text>
                </view>
              </view>
              <view class="customer-list-actions">
                <view class="customer-action-btn edit" catchtap="onEditCustomer" data-index="{{index}}">编辑</view>
                <view class="customer-action-btn delete" catchtap="onDeleteCustomer" data-index="{{index}}">删除</view>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>

      <!-- 新增/编辑客户弹窗 -->
      <view class="modal-mask" wx:if="{{showAddCustomerModal}}">
        <view class="modal-backdrop" catchtap="onCloseAddCustomer"></view>
        <view class="modal-content">
          <view class="modal-header">
            <text class="modal-title">{{editingCustomerId ? '编辑客户' : '新增客户'}}</text>
          </view>
          <view class="form-item">
            <text class="form-label">客户名称</text>
            <input class="form-input" value="{{newCustomer.name}}" bindinput="onNewCustomerInput" data-field="name" placeholder="请输入客户名称" />
          </view>
          <view class="form-item">
            <text class="form-label">客户编码</text>
            <input class="form-input" value="{{newCustomer.code}}" bindinput="onNewCustomerInput" data-field="code" placeholder="选填" />
          </view>
          <view class="form-item">
            <text class="form-label">OEM层级</text>
            <picker range="{{oemTierOptions}}" value="{{oemTierOptions.indexOf(newCustomer.oemTier)}}" bindchange="onNewCustomerOemChange">
              <view class="form-input picker-text">{{newCustomer.oemTier || '选择'}}</view>
            </picker>
          </view>
          <view class="form-item">
            <text class="form-label">联系人</text>
            <input class="form-input" value="{{newCustomer.contactName}}" bindinput="onNewCustomerInput" data-field="contactName" placeholder="选填" />
          </view>
          <view class="form-item">
            <text class="form-label">联系电话</text>
            <input class="form-input" value="{{newCustomer.contactPhone}}" bindinput="onNewCustomerInput" data-field="contactPhone" placeholder="选填" />
          </view>
          <view class="modal-footer">
            <view class="modal-btn cancel" catchtap="onCloseAddCustomer">取消</view>
            <view class="modal-btn confirm" catchtap="onConfirmAddCustomer">
              {{editingCustomerId ? '保存修改' : '确认新增'}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ==================== 技术Tab ==================== -->
    <view class="panel tech-panel {{techReadonly ? 'readonly-panel' : ''}}" wx:if="{{mainTab === 'tech'}}">

      <!-- 产品规格卡片 -->
      <view class="card highlight-card">
        <view class="card-header toggle-header" bindtap="toggleTechSection" data-key="techSpecExpanded">
          <text class="card-title">产品规格</text>
          <view class="toggle-arrow {{techSpecExpanded ? 'expanded' : ''}}"></view>
        </view>
        <view wx:if="{{techSpecExpanded}}">
          <view class="form-row">
            <view class="form-item">
              <text class="form-label">冷凝器型号</text>
              <input class="form-input" value="{{specData.partNo}}" bindinput="onSpecInput" data-field="partNo" placeholder="-" />
            </view>
          </view>
          <view class="spec-group-box">
            <text class="spec-group-title">总成尺寸 (L × W × H)</text>
            <view class="spec-group-row">
              <input class="spec-group-input" type="digit" value="{{specData.sizeL}}" bindinput="onSpecInput" data-field="sizeL" placeholder="长" />
              <text class="spec-group-sep">×</text>
              <input class="spec-group-input" type="digit" value="{{specData.sizeW}}" bindinput="onSpecInput" data-field="sizeW" placeholder="宽" />
              <text class="spec-group-sep">×</text>
              <input class="spec-group-input" type="digit" value="{{specData.sizeH}}" bindinput="onSpecInput" data-field="sizeH" placeholder="高" />
            </view>
          </view>
          <view class="spec-group-box">
            <text class="spec-group-title">芯体尺寸 (中心/宽/厚)</text>
            <view class="spec-group-row">
              <input class="spec-group-input" type="digit" value="{{specData.coreCenter}}" bindinput="onSpecInput" data-field="coreCenter" placeholder="中心距" />
              <input class="spec-group-input" type="digit" value="{{specData.coreWidth}}" bindinput="onSpecInput" data-field="coreWidth" placeholder="芯宽" />
              <input class="spec-group-input" type="digit" value="{{specData.coreThickness}}" bindinput="onSpecInput" data-field="coreThickness" placeholder="芯厚" />
            </view>
          </view>
        </view>
      </view>

      <!-- 性能参数卡片 -->
      <view class="card highlight-card">
        <view class="card-header toggle-header" bindtap="toggleTechSection" data-key="techPerfExpanded">
          <text class="card-title">性能参数</text>
          <view class="toggle-arrow {{techPerfExpanded ? 'expanded' : ''}}"></view>
        </view>
        <view wx:if="{{techPerfExpanded}}">
          <view class="form-row">
            <view class="form-item half">
              <text class="form-label">制冷剂</text>
              <picker range="{{refrigerantOptions}}" value="{{specData.refrigerant}}" bindchange="onRefrigerantChange">
                <view class="form-input picker-value">{{specData.refrigerant || '-'}}</view>
              </picker>
            </view>
            <view class="form-item half">
              <text class="form-label">换热量</text>
              <view class="input-with-unit">
                <input class="form-input" type="digit" value="{{specData.heatExchange}}" bindinput="onSpecInput" data-field="heatExchange" placeholder="-" />
                <text class="input-unit">W</text>
              </view>
            </view>
          </view>
          <view class="form-row">
            <view class="form-item half">
              <text class="form-label">额定风速</text>
              <view class="input-with-unit">
                <input class="form-input" type="digit" value="{{specData.windSpeed}}" bindinput="onSpecInput" data-field="windSpeed" placeholder="-" />
                <text class="input-unit">m/s</text>
              </view>
            </view>
            <view class="form-item half">
              <text class="form-label">压降</text>
              <view class="input-with-unit">
                <input class="form-input" type="digit" value="{{specData.pressureDrop}}" bindinput="onSpecInput" data-field="pressureDrop" placeholder="-" />
                <text class="input-unit">kPa</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- ===== 技术材料动态表格 ===== -->
      <!-- 工具栏 -->
      <view class="cp-toolbar">
        <view class="cp-view-switcher">
          <view class="cp-view-btn {{techViewMode === 'overview' ? 'active' : ''}}" bindtap="switchTechViewMode" data-mode="overview">总览</view>
          <view class="cp-view-btn {{techViewMode === 'table' ? 'active' : ''}}" bindtap="switchTechViewMode" data-mode="table">表格</view>
        </view>
        <view class="prod-btn tpl" catchtap="openPartPresetManager" wx:if="{{!techReadonly}}">模版管理</view>
        <view class="prod-btn {{techEditing ? 'done' : 'edit'}}" bindtap="toggleTechEditing" wx:if="{{!techReadonly}}">{{techEditing ? '完成' : '编辑'}}</view>
      </view>

      <view class="cp-address-bar" wx:if="{{techFocusedCellAddress}}">
        <text class="cp-address-icon">fx</text>
        <text class="cp-address-text">{{techFocusedCellAddress}}</text>
      </view>

      <!-- 分类区域 -->
      <view class="cp-section card" wx:for="{{techMaterialData.categories}}" wx:key="key" wx:for-item="cat">
        <view class="cp-section-header" bindtap="toggleTechCategory" data-ckey="{{cat.key}}">
          <view class="cp-section-left">
            <text class="cp-collapse-icon">{{cat.collapsed ? '▶' : '▼'}}</text>
            <text class="cp-section-label">{{cat.label}}</text>
            <text class="cp-section-count">({{cat.rows.length}})</text>
          </view>
          <view class="cp-section-subtotal">
            <text>小计: ¥{{cat.subtotal || '0.00'}}</text>
          </view>
        </view>

        <!-- ===== 表格模式（编辑或table视图） ===== -->
        <view wx:if="{{!cat.collapsed && cat.mergedColumns.length && techViewMode === 'table'}}">
          <scroll-view class="cp-table-scroll" scroll-x>
            <view class="cp-table">
              <!-- 第一层表头：大分组 -->
              <view class="cp-row header header-top">
                <text class="cp-cell cp-cell-no">No.</text>
                <text class="cp-cell cp-cell-partno" wx:if="{{cat.key !== 'D'}}">零件编号</text>
                <text class="cp-cell cp-cell-name" wx:if="{{cat.key !== 'D'}}">零件名称</text>
                <text class="cp-cell cp-cell-material" wx:if="{{cat.key !== 'D'}}">材质</text>
                <text class="cp-cell cp-cell-group-spec" style="flex: 0 0 {{cat.specColCount * 120}}rpx; min-width: {{cat.specColCount * 120}}rpx;" wx:if="{{cat.specColCount > 0}}">{{cat.specColumns[0].group || '材料规格'}}</text>
                <text class="cp-cell" wx:for="{{cat.commonColumns}}" wx:key="key" wx:for-item="col">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}}</text>
                <text class="cp-cell cp-cell-action" wx:if="{{techEditing && !techReadonly}}">操作</text>
              </view>
              <!-- 数据行 -->
              <view class="cp-row" wx:for="{{cat.rows}}" wx:key="id" wx:for-item="row">
                <text class="cp-cell cp-cell-no">{{index + 1}}</text>
                <text class="cp-cell cp-cell-partno" wx:if="{{cat.key !== 'D'}}">{{row._partNo || '-'}}</text>
                <text class="cp-cell cp-cell-name" wx:if="{{cat.key !== 'D'}}">{{row._partName || '-'}}</text>
                <view class="cp-cell cp-cell-material" wx:if="{{cat.key !== 'D'}}">
                  <block wx:if="{{techEditing && !techReadonly}}">
                    <input class="cp-input" type="text" value="{{row._material}}" bindinput="onTechMaterialFieldInput" data-ckey="{{cat.key}}" data-id="{{row.id}}" placeholder="材质" />
                  </block>
                  <block wx:else>
                    <text>{{row._material || '-'}}</text>
                  </block>
                </view>
                <!-- 规格列 -->
                <view class="cp-cell" wx:for="{{cat.specColumns}}" wx:key="key" wx:for-item="col">
                  <block wx:if="{{!row._colKeys[col.key]}}">
                    <text class="cp-empty-cell"></text>
                  </block>
                  <block wx:elif="{{row._outputKeys[col.key]}}">
                    <text class="cp-output-val">{{row[col.key] || '0'}}</text>
                  </block>
                  <block wx:elif="{{techEditing && !techReadonly}}">
                    <input class="cp-input" type="{{col.type === 'number' ? 'digit' : 'text'}}" value="{{row[col.key]}}" bindinput="onTechMaterialInput" bindfocus="onTechCellFocus" bindblur="onTechCellBlur" data-ckey="{{cat.key}}" data-id="{{row.id}}" data-field="{{col.key}}" />
                  </block>
                  <block wx:else>
                    <text>{{row[col.key] || '-'}}</text>
                  </block>
                </view>
                <!-- 通用列 -->
                <view class="cp-cell" wx:for="{{cat.commonColumns}}" wx:key="key" wx:for-item="col">
                  <block wx:if="{{!row._colKeys[col.key]}}">
                    <text class="cp-empty-cell"></text>
                  </block>
                  <block wx:elif="{{row._outputKeys[col.key]}}">
                    <text class="cp-output-val">{{row[col.key] || '0'}}</text>
                  </block>
                  <block wx:elif="{{techEditing && !techReadonly}}">
                    <input class="cp-input" type="{{col.type === 'number' ? 'digit' : 'text'}}" value="{{row[col.key]}}" bindinput="onTechMaterialInput" bindfocus="onTechCellFocus" bindblur="onTechCellBlur" data-ckey="{{cat.key}}" data-id="{{row.id}}" data-field="{{col.key}}" />
                  </block>
                  <block wx:else>
                    <text>{{row[col.key] || '-'}}</text>
                  </block>
                </view>
                <view class="cp-cell cp-cell-action" wx:if="{{techEditing && !techReadonly}}">
                  <view class="row-action-btn copy" catchtap="copyTechRow" data-ckey="{{cat.key}}" data-id="{{row.id}}">复制</view>
                  <view class="row-action-btn move" catchtap="moveTechRow" data-ckey="{{cat.key}}" data-id="{{row.id}}" data-dir="up">↑</view>
                  <view class="row-action-btn move" catchtap="moveTechRow" data-ckey="{{cat.key}}" data-id="{{row.id}}" data-dir="down">↓</view>
                  <view class="row-action-btn delete" catchtap="deleteTechRow" data-ckey="{{cat.key}}" data-id="{{row.id}}">删除</view>
                </view>
              </view>
            </view>
          </scroll-view>
          <!-- 加工费行（有加工费的零件） -->
          <view class="cp-process-fee-bar" wx:if="{{cat.key !== 'D' && cat.hasProcessFeeRows && techEditing && !techReadonly}}">
            <view class="cp-fee-item" wx:for="{{cat.rows}}" wx:key="id" wx:for-item="row" wx:if="{{row._hasProcessFee}}">
              <text class="cp-fee-label">{{row._partName}} - {{row._processFeeLabel || '加工费'}}:</text>
              <input class="cp-fee-input" type="digit" value="{{row._processFeeValue}}" bindinput="onProcessFeeInput" data-ckey="{{cat.key}}" data-id="{{row.id}}" />
            </view>
          </view>
        </view>

        <!-- ===== 总览模式 ===== -->
        <view wx:if="{{!cat.collapsed && cat.rows.length && techViewMode === 'overview'}}" class="ov-section">
          <view class="ov-card" wx:for="{{cat.rows}}" wx:key="id" wx:for-item="row">
            <!-- 卡片摘要行（点击展开/收起） -->
            <view class="ov-card-summary" bindtap="togglePartDetail" data-id="{{row.id}}">
              <view class="ov-card-left">
                <text class="ov-card-index">{{index + 1}}</text>
                <view class="ov-card-info">
                  <text class="ov-card-name">{{row._partNo ? row._partNo + ' ' : ''}}{{row._partName || '未命名零件'}}</text>
                  <text class="ov-card-spec">{{row._specSummary || '暂无规格'}}</text>
                </view>
              </view>
              <view class="ov-card-right">
                <text class="ov-card-amount">¥{{row[row._amountKey] || '0'}}</text>
                <text class="ov-card-arrow">{{techExpandedRowId === row.id ? '▲' : '▼'}}</text>
                <text class="ov-card-del" catchtap="deleteOvRow" data-ckey="{{cat.key}}" data-id="{{row.id}}" wx:if="{{!techReadonly}}">×</text>
              </view>
            </view>
            <!-- 展开详情 -->
            <view class="ov-detail" wx:if="{{techExpandedRowId === row.id}}">
              <view class="ov-detail-grid">
                <view class="ov-detail-item" wx:if="{{cat.key !== 'D'}}">
                  <text class="ov-detail-label">材质</text>
                  <input class="ov-input" type="text" value="{{row._material}}" bindinput="onTechMaterialFieldInput" data-ckey="{{cat.key}}" data-id="{{row.id}}" placeholder="输入材质" disabled="{{techReadonly}}" />
                </view>
                <view class="ov-detail-item" wx:if="{{row._hasProcessFee}}">
                  <text class="ov-detail-label">{{row._processFeeLabel || '加工费'}}</text>
                  <input class="ov-input" type="digit" value="{{row._processFeeValue}}" bindinput="onProcessFeeInput" data-ckey="{{cat.key}}" data-id="{{row.id}}" placeholder="0" disabled="{{techReadonly}}" />
                </view>
                <view class="ov-detail-item mc-info" wx:if="{{row._materialCost}}">
                  <text class="ov-detail-label">材料系数</text>
                  <text class="ov-detail-value">{{row._materialCost.spec}} / 系数{{row._materialCost.factor}}</text>
                </view>
                <block wx:for="{{row._columns}}" wx:key="key" wx:for-item="col" wx:if="{{row._colKeys[col.key]}}">
                  <view class="ov-detail-item" wx:if="{{!row._outputKeys[col.key]}}">
                    <text class="ov-detail-label">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}}</text>
                    <input class="ov-input" type="{{col.type === 'number' ? 'digit' : 'text'}}" value="{{row[col.key]}}" bindinput="onTechMaterialInput" data-ckey="{{cat.key}}" data-id="{{row.id}}" data-field="{{col.key}}" placeholder="-" disabled="{{techReadonly}}" />
                  </view>
                  <view class="ov-detail-item" wx:if="{{row._outputKeys[col.key]}}">
                    <text class="ov-detail-label">{{col.label}}</text>
                    <text class="ov-detail-value ov-output">{{row[col.key] || '0'}}{{col.unit ? ' ' + col.unit : ''}}</text>
                  </view>
                </block>
              </view>
            </view>
          </view>
        </view>

        <view wx:if="{{!cat.collapsed && !cat.mergedColumns.length && !cat.rows.length}}" class="cp-empty">
          <text>暂无零件，点击下方按钮添加</text>
        </view>

        <!-- 每个分区的添加零件按钮 -->
        <view class="cp-section-add" wx:if="{{!cat.collapsed && !techReadonly}}">
          <view class="prod-btn primary cp-add-part-btn" catchtap="openAddPartSearch" data-ckey="{{cat.key}}">+ {{cat.key === 'D' ? '添加' : '添加零件'}}</view>
          <view class="prod-btn" catchtap="addTechEmptyRow" data-ckey="{{cat.key}}" wx:if="{{cat.rows.length}}">+ 空行</view>
        </view>
      </view>

      <!-- 技术Tab底部总计 -->
      <view class="cp-grand-total card">
        <view class="cp-grand-total-row">
          <text class="cp-grand-total-label">材料成本合计</text>
          <text class="cp-grand-total-value">¥ {{techMaterialTotal || '0'}}</text>
        </view>
      </view>
    </view>

    <!-- ==================== 生产工序Tab ==================== -->
    <view class="panel prod-panel {{prodReadonly ? 'readonly-panel' : ''}}" wx:if="{{mainTab === 'prod'}}">

      <!-- ===== 自定义模式 ===== -->
      <view wx:if="{{customProcessData}}">
        <!-- 统一工具栏 -->
        <view class="cp-toolbar">
          <block wx:if="{{!prodReadonly}}">
            <view class="cp-toolbar-menu-wrap">
              <view class="prod-btn primary" catchtap="toggleProdAddMenu">+ 添加</view>
              <view class="cp-dropdown-menu" wx:if="{{showProdAddMenu}}">
                <view class="cp-dropdown-item" catchtap="openCustomProcessModal" data-skey="">添加工序</view>
                <view class="cp-dropdown-item" catchtap="openAddSectionModal">添加工序区域</view>
                <view class="cp-dropdown-item" catchtap="openAddSectionModal" data-dtype="energy" data-subtype="device">添加设备消耗</view>
                <view class="cp-dropdown-item" catchtap="openAddSectionModal" data-dtype="energy" data-subtype="material">添加辅料消耗</view>
                <view class="cp-dropdown-item" catchtap="openAddSectionModal" data-dtype="moldFee">添加模具费区域</view>
              </view>
            </view>
            <view class="cp-toolbar-menu-wrap">
              <view class="prod-btn tpl" catchtap="toggleProdTplMenu">模版</view>
              <view class="cp-dropdown-menu" wx:if="{{showProdTplMenu}}">
                <view class="cp-dropdown-item" catchtap="openTemplateManager">管理模版</view>
                <view class="cp-dropdown-item" catchtap="openApplyTemplate">运用模版</view>
              </view>
            </view>
            <view class="prod-btn" catchtap="openSummaryEditor">汇总</view>
            <view class="prod-btn {{prodEditing ? 'done' : 'edit'}}" bindtap="toggleProdEditing">{{prodEditing ? '完成' : '编辑'}}</view>
          </block>
        </view>

        <view class="cp-address-bar" wx:if="{{focusedCellAddress}}">
          <text class="cp-address-icon">fx</text>
          <text class="cp-address-text">{{focusedCellAddress}}</text>
        </view>

        <!-- 工序区域 -->
        <view class="area-title-bar">
          <text class="prod-section-title">工序</text>
          <view class="area-summary-badge" catchtap="openAreaSummary" data-dtype="process">汇总: ¥{{processAreaTotal || '0'}}</view>
        </view>
        <view class="cp-section card" wx:for="{{customProcessData.sections}}" wx:key="key" wx:for-item="sec">
          <view class="cp-section-header" bindtap="toggleSectionCollapse" data-skey="{{sec.key}}">
            <view class="cp-section-left">
              <text class="cp-collapse-icon">{{sec.collapsed ? '▶' : '▼'}}</text>
              <text class="cp-section-label">{{sec.label}}<text wx:if="{{prodEditing && !prodReadonly}}" class="cp-coord-hint">{{sec.key}}</text></text>
            </view>
            <view class="cp-section-actions" catchtap="">
              <block wx:if="{{prodEditing && !prodReadonly}}">
                <view class="cp-action-btn" catchtap="renameSection" data-skey="{{sec.key}}">重命名</view>
                <view class="cp-action-btn" catchtap="openColumnEditor" data-skey="{{sec.key}}">编辑列</view>
                <view class="cp-action-btn danger" catchtap="deleteSection" data-skey="{{sec.key}}">删除</view>
              </block>
              <block wx:else>
                <view class="cp-action-btn quick-add" catchtap="openCustomProcessModal" data-skey="{{sec.key}}" wx:if="{{!prodReadonly}}">+</view>
              </block>
            </view>
          </view>

          <view wx:if="{{!sec.collapsed}}">
            <scroll-view class="cp-table-scroll" scroll-x>
              <view class="cp-table">
                <view class="cp-row header">
                  <text class="cp-cell cp-cell-no">No.</text>
                  <text class="cp-cell" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">{{col.label}}{{col.unit ? '(' + col.unit + ')' : ''}}<text wx:if="{{prodEditing && !prodReadonly}}" class="cp-coord-hint">{{col.key}}</text></text>
                  <text class="cp-cell cp-cell-action" wx:if="{{prodEditing && !prodReadonly}}">操作</text>
                </view>
                <view class="cp-row" wx:for="{{sec.rows}}" wx:key="id" wx:for-item="row">
                  <text class="cp-cell cp-cell-no">{{prodEditing && !prodReadonly ? '[' + (index + 1) + ']' : (index + 1)}}</text>
                  <view class="cp-cell" wx:for="{{sec.columns}}" wx:key="key" wx:for-item="col">
                    <block wx:if="{{col.role === 'output'}}">
                      <text class="cp-output-val {{row._formulas[col.key] ? 'has-custom-formula' : ''}}" catchtap="openRowFormulaEditor" data-skey="{{sec.key}}" data-id="{{row.id}}" data-field="{{col.key}}" data-dtype="process">{{row[col.key] || '0'}}</text>
                    </block>
                    <block wx:elif="{{prodEditing && !prodReadonly}}">
                      <input class="cp-input" type="{{col.type === 'number' ? 'digit' : 'text'}}" value="{{row[col.key]}}" bindinput="onCustomProcessInput" bindfocus="onCellFocus" bindblur="onCellBlur" data-skey="{{sec.key}}" data-id="{{row.id}}" data-field="{{col.key}}" />
                    </block>
                    <block wx:else>
                      <text>{{row[col.key] || '-'}}</text>
                    </block>
                  </view>
                  <view class="cp-cell cp-cell-action" wx:if="{{prodEditing && !prodReadonly}}">
                    <view class="row-action-btn copy" catchtap="copyRow" data-skey="{{sec.key}}" data-id="{{row.id}}">复制</view>
                    <view class="row-action-btn move" catchtap="moveRow" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dir="up">↑</view>
                    <view class="row-action-btn move" catchtap="moveRow" data-skey="{{sec.key}}" data-id="{{row.id}}" data-dir="down">↓</view>
                    <view class="row-action-btn delete" catchtap="deleteCustomProcess" data-skey="{{sec.key}}" data-id="{{row.id}}">删除</view>
                  </view>
                </view>
              </view>
            </scroll-view>
            <!-- 区域小计 -->
            <view class="cp-subtotal-bar" wx:if="{{sec.rows.length > 0}}">
              <text class="cp-subtotal-label">小计</text>
              <picker class="cp-subtotal-picker" bindchange="onSubtotalKeyChange" data-skey="{{sec.key}}" range="{{sec._numCols}}" range-key="label">
                <view class="cp-subtotal-col">{{sec.subtotalLabel || '选择汇总列'}} ▼</view>
              </picker>
              <text class="cp-subtotal-value">{{sec.subtotalValue || '—'}}</text>
            </view>
            <view class="cp-empty" wx:if="{{!sec.rows.length && !sec.columns.length}}">
              <text>暂无工序，请先编辑列再添加</text>
            </view>
            <view class="cp-add-row" wx:if="{{sec.columns.length && !prodReadonly}}" catchtap="addEmptyRow" data-skey="{{sec.key}}">
              <text>+ 添加一行</text>
            </view>
          </view>
        </view>

        <!-- ===== 能耗区域 ===== -->
        <view class="area-title-bar">
          <text class="energy-section-title">能耗</text>
          <view class="area-summary-badge energy" catchtap="openAreaSummary" data-dtype="energy">汇总: ¥{{energyAreaTotal || '0'}}</view>
        </view>

        <view class="cp-empty" wx:if="{{!customProcessData.energySections.length}}">
          <text>暂无能耗区域，通过顶部"+ 添加"菜单创建</text>
        </view>

        <view class="cp-section card" wx:for="{{customProcessData.energySections}}" wx:key="key" wx:for-item="sec">
          <view class="cp-section-header" bindtap="toggleSectionCollapse" data-skey="{{sec.key}}" data-dtype="energy">
            <view class="cp-section-left">
              <text class="cp-collapse-icon">{{sec.collapsed ? '▶' : '▼'}}</text>
              <text class="cp-section-label">{{sec.label}}<text wx:if="{{prodEditing && !prodReadonly}}" class="cp-coord-hint">{{sec.key}}</text></text>
            </view>
            <view class="cp-section-actions" catchtap="">
              <block wx:if="{{prodEditing && !prodReadonly}}">
                <view class="cp-action-btn" catchtap="renameSection" data-skey="{{sec.key}}" data-dtype="energy">重命名</view>
                <view class="cp-action-btn danger" catchtap="deleteSection" data-skey="{{sec.key}}" data-dtype="energy">删除</view>
              </block>
              <block wx:else>
                <view class="cp-action-btn quick-add" catchtap="{{sec.subtype === 'device' ? 'openDeviceTemplateSelector' : 'openCustomProcessModal'}}" data-skey="{{sec.key}}" data-dtype="energy" data-subtype="{{sec.subtype}}" wx:if="{{!prodReadonly}}">+</view>
              </block>
            </view>
          </view>

          <view wx:if="{{!sec.collapsed}}">
