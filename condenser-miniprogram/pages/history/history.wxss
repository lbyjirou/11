/* 历史报价页 - 生态未来主义风格 */

page {
  background: linear-gradient(180deg, #f0fdf4 0%, #ecfdf5 50%, #f5f5f5 100%);
}

.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 88rpx 30rpx 20rpx;
  background: linear-gradient(180deg, #f0fdf4 0%, transparent 100%);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(34, 197, 94, 0.1);
  margin-right: 20rpx;
}

.back-btn:active {
  background: rgba(34, 197, 94, 0.2);
  transform: scale(0.95);
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #22c55e;
  border-bottom: 4rpx solid #22c55e;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #166534;
}

/* 搜索栏 */
.search-bar {
  padding: 0 30rpx 20rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(34, 197, 94, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
}

/* 列表区域 */
.list-area {
  flex: 1;
  padding: 0 30rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 报价列表 */
.quote-list {
  padding-bottom: 40rpx;
}

.quote-item {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(34, 197, 94, 0.08);
}

.quote-item:active {
  background: rgba(255, 255, 255, 0.7);
}

.quote-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.quote-no {
  font-size: 24rpx;
  color: #6b7280;
  font-family: monospace;
}

.quote-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.quote-status.active {
  background: rgba(34, 197, 94, 0.1);
  color: #16a34a;
}

.quote-status.inactive {
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.quote-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.quote-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.customer-name {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
}

.product-type {
  font-size: 24rpx;
  color: #9ca3af;
}

.quote-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-value {
  font-size: 36rpx;
  color: #ea580c;
  font-weight: 700;
}

.price-qty {
  font-size: 24rpx;
  color: #9ca3af;
}

.quote-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f4f6;
  margin-top: 12rpx;
}

.create-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.view-more {
  font-size: 24rpx;
  color: #22c55e;
}

/* 加载更多 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  gap: 16rpx;
}

.loading-more text {
  font-size: 24rpx;
  color: #9ca3af;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(34, 197, 94, 0.2);
  border-top-color: #22c55e;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-spinner.large {
  width: 48rpx;
  height: 48rpx;
  border-width: 6rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more text {
  font-size: 24rpx;
  color: #d1d5db;
}

/* 全屏加载 */
.loading-full {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-full text {
  font-size: 26rpx;
  color: #9ca3af;
}

/* 底部占位 */
.bottom-placeholder {
  height: 40rpx;
}

/* 操作弹窗 */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  padding-bottom: env(safe-area-inset-bottom);
}

.action-header {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #f3f4f6;
}

.action-title {
  display: block;
  font-size: 28rpx;
  color: #374151;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.action-subtitle {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

.action-list {
  padding: 16rpx 0;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 28rpx 40rpx;
}

.action-item:active {
  background: #f9fafb;
}

.action-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
}

.action-text {
  font-size: 30rpx;
  color: #374151;
}

.action-item.danger .action-text {
  color: #dc2626;
}

.action-cancel {
  padding: 30rpx;
  text-align: center;
  border-top: 8rpx solid #f3f4f6;
}

.action-cancel text {
  font-size: 30rpx;
  color: #6b7280;
}

.action-cancel:active {
  background: #f9fafb;
}
