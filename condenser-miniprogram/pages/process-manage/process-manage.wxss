/* 工序管理页 - 生态未来主义风格 */

page {
  background: linear-gradient(180deg, #f0fdf4 0%, #ecfdf5 50%, #f5f5f5 100%);
}

.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 88rpx 30rpx 20rpx;
  background: linear-gradient(180deg, #f0fdf4 0%, transparent 100%);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(34, 197, 94, 0.1);
  margin-right: 20rpx;
}

.back-btn:active {
  background: rgba(34, 197, 94, 0.2);
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #22c55e;
  border-bottom: 4rpx solid #22c55e;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
  color: #166534;
}

/* 操作栏 */
.action-bar {
  padding: 0 30rpx 20rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.3);
}

.add-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.add-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(34, 197, 94, 0.2);
}

/* 列表区域 */
.list-area {
  flex: 1;
  height: 0;
  padding: 0 30rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 工序列表 */
.process-list {
  padding: 20rpx 0;
}

.process-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(34, 197, 94, 0.08);
}

.process-item.disabled {
  opacity: 0.6;
  background: rgba(245, 245, 245, 0.9);
}

.process-info {
  flex: 1;
}

.process-name {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.process-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.process-price {
  font-size: 26rpx;
  color: #ea580c;
  font-weight: 500;
}

.process-tag {
  font-size: 22rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.process-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.process-status.active {
  background: rgba(34, 197, 94, 0.1);
  color: #16a34a;
}

.process-status.inactive {
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.process-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  text-align: center;
}

.action-btn.edit {
  background: rgba(59, 130, 246, 0.1);
  color: #2563eb;
}

.action-btn.delete {
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.action-btn.toggle {
  min-width: 80rpx;
}

.action-btn.toggle.on {
  background: rgba(34, 197, 94, 0.1);
  color: #16a34a;
}

.action-btn.toggle.off {
  background: rgba(156, 163, 175, 0.1);
  color: #6b7280;
}

/* 加载 */
.loading-full {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-full text {
  font-size: 26rpx;
  color: #9ca3af;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(34, 197, 94, 0.2);
  border-top-color: #22c55e;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-spinner.large {
  width: 48rpx;
  height: 48rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
}

.modal-close {
  font-size: 40rpx;
  color: #9ca3af;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.form-item.half {
  flex: 1;
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #374151;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #22c55e;
  background: #fff;
}

.form-display {
  height: 80rpx;
  padding: 0 24rpx;
  background: #f0fdf4;
  border: 2rpx solid #86efac;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #16a34a;
  font-weight: 500;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
}

.picker-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #374151;
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #9ca3af;
  border-bottom: 3rpx solid #9ca3af;
  transform: rotate(45deg);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 30rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.btn-confirm::after {
  border: none;
}

.bottom-placeholder {
  height: 40rpx;
}

/* 列定义编辑器 */
.form-divider {
  font-size: 26rpx; color: #374151; font-weight: 500;
  padding: 16rpx 0 12rpx; border-top: 1rpx solid #e5e7eb; margin-top: 12rpx;
}
.col-list { margin-bottom: 16rpx; }
.col-item {
  background: #f9fafb; border-radius: 12rpx; padding: 16rpx;
  margin-bottom: 12rpx; border: 1rpx solid #e5e7eb;
}
.col-row-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.col-row-bottom { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; }
.col-input {
  flex: 1; min-width: 0; height: 60rpx; padding: 0 16rpx;
  background: #fff; border: 1rpx solid #e5e7eb; border-radius: 8rpx;
  font-size: 24rpx; color: #374151; box-sizing: border-box;
}
.col-input.name { flex: 2; }
.col-input.key { flex: 2; }
.col-input.unit { flex: 1; max-width: 120rpx; }
.col-input.formula { flex: 2; }
.col-del {
  width: 48rpx; height: 48rpx; display: flex; align-items: center;
  justify-content: center; color: #dc2626; font-size: 32rpx;
  background: rgba(239,68,68,0.1); border-radius: 50%;
}
.col-picker { flex-shrink: 0; }
.col-tag {
  font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 12rpx;
}
.col-tag.input { background: rgba(59,130,246,0.1); color: #2563eb; }
.col-tag.output { background: rgba(234,179,8,0.1); color: #ca8a04; }
.col-add {
  text-align: center; font-size: 26rpx; color: #22c55e;
  padding: 16rpx 0; border: 2rpx dashed #86efac; border-radius: 12rpx;
}

/* 区域模糊搜索 */
.section-search-wrap { position: relative; }
.section-dropdown {
  position: absolute; top: 100%; left: 0; right: 0;
  background: #fff; border: 1rpx solid #e5e7eb; border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.12); z-index: 200;
  margin-top: 4rpx; overflow: hidden;
}
.section-option {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 24rpx; border-bottom: 1rpx solid #f3f4f6;
}
.section-option:last-child { border-bottom: none; }
.section-option:active { background: #f0fdf4; }
.section-option-label { font-size: 26rpx; color: #374151; }
.section-option-key { font-size: 22rpx; color: #9ca3af; font-family: monospace; }
