.page-container { min-height: 100vh; background: #f5f5f5; }
.nav-bar { display: flex; align-items: center; padding: 88rpx 24rpx 20rpx; background: #07c160; }
.back-btn { padding: 16rpx; }
.back-arrow { width: 20rpx; height: 20rpx; border-left: 4rpx solid #fff; border-bottom: 4rpx solid #fff; transform: rotate(45deg); }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 600; color: #fff; margin-right: 52rpx; }
.content-area { height: calc(100vh - 176rpx); padding: 0 24rpx 40rpx; }

.section-header { display: flex; align-items: baseline; padding: 32rpx 8rpx 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; flex: 1; }
.section-hint { font-size: 24rpx; color: #999; }

.card { background: #fff; border-radius: 16rpx; padding: 0 28rpx; margin-bottom: 8rpx; }

.mode-switch { display: flex; gap: 20rpx; padding: 24rpx 0; }
.mode-option { flex: 1; text-align: center; padding: 24rpx 0; border: 2rpx solid #e0e0e0; border-radius: 12rpx; font-size: 28rpx; color: #666; }
.mode-option .mode-desc { display: block; font-size: 22rpx; color: #999; margin-top: 8rpx; }
.mode-option.active { border-color: #07c160; background: #f0fdf4; color: #333; }

.config-item { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.config-item:last-child { border-bottom: none; }
.config-info { flex: 1; }
.config-name { font-size: 28rpx; color: #333; }
.config-desc { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.config-input-wrap { display: flex; align-items: center; gap: 8rpx; }
.config-input { width: 120rpx; height: 64rpx; background: #f5f5f5; border-radius: 10rpx; text-align: center; font-size: 28rpx; }
.config-unit { font-size: 24rpx; color: #999; }

.save-btn { margin: 40rpx 0; padding: 24rpx 0; background: #07c160; color: #fff; text-align: center; border-radius: 12rpx; font-size: 30rpx; font-weight: 500; }
